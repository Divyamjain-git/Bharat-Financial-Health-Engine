    "var_a833224a72f0": {
      "type": "variant",
      "label": "Redesign: Budget Planner (Variant 1 Style)",
      "parentId": "var_f4bb256afb3f",
      "themeId": null,
      "rect": {
        "x": 4620,
        "y": 0,
        "w": 1440,
