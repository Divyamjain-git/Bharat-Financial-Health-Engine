      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --gold: #D4AF37;\n    --gold-glow: rgba(212, 175, 55, 0.4);\n    --bg-black: #000000;\n    --glass: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n    --teal: #0DCFAA;\n  }\n\n  body {\n    background-color: var(--bg-black);\n    color: #ffffff;\n    font-family: 'Instrument Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  h1, h2, h3, .font-display {\n    font-family: 'Cabinet Grotesk', sans-serif;\n    letter-spacing: -0.02em;\n  }\n\n  .tabular-nums {\n    font-variant-numeric: tabular-nums;\n  }\n\n  .grid-pattern {\n    background-image: radial-gradient(rgba(212, 175, 55, 0.1) 1px, transparent 1px);\n    background-size: 30px 30px;\n  }\n\n  .glass-card {\n    background: linear-gradient(145deg, rgba(20, 20, 20, 0.4) 0%, rgba(10, 10, 10, 0.6) 100%);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n    border-top: 1px solid rgba(255, 255, 255, 0.12);\n    border-left: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n    border-radius: 24px;\n    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .scenario-btn {\n    background: rgba(255, 255, 255, 0.02);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    border-radius: 16px;\n    padding: 20px;\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    cursor: pointer;\n    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);\n    text-align: left;\n    width: 100%;\n  }\n\n  .scenario-btn:hover {\n    background: rgba(255, 255, 255, 0.05);\n    border-color: rgba(212, 175, 55, 0.3);\n  }\n\n  .scenario-btn.active {\n    background: rgba(212, 175, 55, 0.08);\n    border-color: var(--gold);\n    box-shadow: 0 0 30px rgba(212, 175, 55, 0.15);\n  }\n\n  .scenario-btn.active .icon-box {\n    background: var(--gold);\n    color: #000;\n    box-shadow: 0 0 20px var(--gold-glow);\n  }\n\n  .icon-box {\n    width: 48px;\n    height: 48px;\n    border-radius: 12px;\n    background: rgba(255, 255, 255, 0.05);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 24px;\n    color: var(--gold);\n    transition: all 0.3s;\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, var(--gold) 0%, #b8860b 100%);\n    color: #000;\n    font-weight: 800;\n    padding: 16px 32px;\n    border-radius: 12px;\n    transition: all 0.3s ease;\n    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.2);\n  }\n\n  .text-glow-gold {\n    text-shadow: 0 0 20px var(--gold-glow);\n  }\n\n  .text-glow-teal {\n    text-shadow: 0 0 20px rgba(13, 207, 170, 0.4);\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .floating {\n    animation: float 4s ease-in-out infinite;\n  }\n\n  /* Custom Range Input Styling */\n  input[type=range] {\n    -webkit-appearance: none;\n    width: 100%;\n    background: transparent;\n  }\n\n  input[type=range]::-webkit-slider-runnable-track {\n    width: 100%;\n    height: 4px;\n    cursor: pointer;\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 2px;\n  }\n\n  input[type=range]::-webkit-slider-thumb {\n    height: 16px;\n    width: 16px;\n    border-radius: 50%;\n    background: var(--gold);\n    cursor: pointer;\n    -webkit-appearance: none;\n    margin-top: -6px;\n    box-shadow: 0 0 10px var(--gold-glow);\n  }\n\n  .alert-overlay {\n    position: absolute;\n    top: 24px;\n    right: 24px;\n    z-index: 100;\n  }\n\n  .push-notification {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    border-left: 4px solid var(--gold);\n    padding: 16px 20px;\n    border-radius: 12px;\n    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    margin-bottom: 12px;\n    animation: slideIn 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;\n  }\n\n  @keyframes slideIn {\n    from { opacity: 0; transform: translateX(50px); }\n    to { opacity: 1; transform: translateX(0); }\n  }\n</style>\n\n<div class=\"&quot;min-h-screen\" grid-pattern relative id=\"&quot;engine-root&quot;\" data-kid=\"1\">\n  \n  <div class=\"&quot;alert-overlay&quot;\" data-kid=\"2\">\n    <div class=\"&quot;push-notification&quot;\" data-kid=\"3\">\n      <div class=\"&quot;w-8\" h-8 rounded-full bg-[#D4AF37] flex items-center justify-center text-[#D4AF37] data-kid=\"4\">\n        <i class=\"&quot;ti\" ti-bell-ringing data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <p class=\"&quot;text-[10px]\" font-black uppercase tracking-widest text-white data-kid=\"7\">Intelligence Alert</p>\n        <p class=\"&quot;text-xs\" font-bold data-kid=\"8\">Debt-to-Income ratio has deviated by -4.2%</p>\n      </div>\n    </div>\n  </div>\n\n  <nav class=\"&quot;flex\" items-center justify-between px-12 h-20 bg-black backdrop-blur-xl border-b border-white data-kid=\"9\">\n    <div class=\"&quot;flex\" items-center gap-3 data-kid=\"10\">\n      <div class=\"&quot;w-10\" h-10 rounded-xl bg-gradient-to-br from-[#D4AF37] to-[#b8860b] flex items-center justify-center font-black text-black text-xl data-kid=\"11\">₹</div>\n      <span class=\"&quot;font-display\" font-black text-2xl tracking-tighter data-kid=\"12\">BFHE</span>\n    </div>\n    <div class=\"&quot;flex\" items-center gap-6 data-kid=\"13\">\n      <span class=\"&quot;text-[10px]\" font-black uppercase tracking-[0.3em] text-white data-kid=\"14\">Precision Simulator v2.0</span>\n      <button class=\"&quot;btn-primary\" text-xs uppercase tracking-widest data-kid=\"15\">Export Report</button>\n    </div>\n  </nav>\n\n  <main class=\"&quot;container\" mx-auto px-12 py-16 data-kid=\"16\">\n    \n    <header class=\"&quot;mb-16&quot;\" data-kid=\"17\">\n      <div class=\"&quot;inline-flex\" items-center gap-2 px-4 py-2 rounded-full bg-[#D4AF37] border border-[#D4AF37] mb-6 data-kid=\"18\">\n        <span class=\"&quot;w-1.5\" h-1.5 rounded-full bg-[#D4AF37] animate-pulse data-kid=\"19\"></span>\n        <span class=\"&quot;text-[10px]\" font-black uppercase tracking-widest text-[#D4AF37] data-kid=\"20\">What-If Engine Active</span>\n      </div>\n      <h1 class=\"&quot;text-6xl\" font-black leading-tight tracking-tighter data-kid=\"21\">\n        Simulate Your <br data-kid=\"22\">\n        <span class=\"&quot;bg-gradient-to-br\" from-[#D4AF37] to-[#F5D76E] bg-clip-text text-transparent text-glow-gold data-kid=\"23\">Financial Destiny.</span>\n      </h1>\n    </header>\n\n    <div class=\"&quot;grid\" lg:grid-cols-12 gap-8 items-start data-kid=\"24\">\n      \n      <aside class=\"&quot;lg:col-span-4\" space-y-4 data-kid=\"25\">\n        <div class=\"&quot;glass-card\" p-8 data-kid=\"26\">\n          <p class=\"&quot;text-[10px]\" font-black uppercase tracking-[0.3em] text-white mb-6 data-kid=\"27\">Simulation Scenarios</p>\n          <div class=\"&quot;space-y-3&quot;\" data-kid=\"28\">\n            <button class=\"&quot;scenario-btn\" active data-kid=\"29\">\n              <div class=\"&quot;icon-box&quot;\" data-kid=\"30\"><i class=\"&quot;ti\" ti-trending-up data-kid=\"31\"></i></div>\n              <div data-kid=\"32\">\n                <p class=\"&quot;text-sm\" font-black data-kid=\"33\">Salary Hike</p>\n                <p class=\"&quot;text-[10px]\" text-white font-bold uppercase tracking-wider data-kid=\"34\">Income Growth Impact</p>\n              </div>\n            </button>\n            <button class=\"&quot;scenario-btn&quot;\" data-kid=\"35\">\n              <div class=\"&quot;icon-box&quot;\" data-kid=\"36\"><i class=\"&quot;ti\" ti-coins data-kid=\"37\"></i></div>\n              <div data-kid=\"38\">\n                <p class=\"&quot;text-sm\" font-black data-kid=\"39\">Debt Liquidation</p>\n                <p class=\"&quot;text-[10px]\" text-white font-bold uppercase tracking-wider data-kid=\"40\">EMI Payoff Strategy</p>\n              </div>\n            </button>\n            <button class=\"&quot;scenario-btn&quot;\" data-kid=\"41\">\n              <div class=\"&quot;icon-box&quot;\" data-kid=\"42\"><i class=\"&quot;ti\" ti-chart-pie data-kid=\"43\"></i></div>\n              <div data-kid=\"44\">\n                <p class=\"&quot;text-sm\" font-black data-kid=\"45\">Expense Optimization</p>\n                <p class=\"&quot;text-[10px]\" text-white font-bold uppercase tracking-wider data-kid=\"46\">Lifestyle Adjustment</p>\n              </div>\n            </button>\n            <button class=\"&quot;scenario-btn&quot;\" data-kid=\"47\">\n              <div class=\"&quot;icon-box&quot;\" data-kid=\"48\"><i class=\"&quot;ti\" ti-shield-check data-kid=\"49\"></i></div>\n              <div data-kid=\"50\">\n                <p class=\"&quot;text-sm\" font-black data-kid=\"51\">Reserve Building</p>\n                <p class=\"&quot;text-[10px]\" text-white font-bold uppercase tracking-wider data-kid=\"52\">Emergency Fund Scaling</p>\n              </div>\n            </button>\n          </div>\n\n          <div class=\"&quot;mt-10\" pt-10 border-t border-white space-y-8 data-kid=\"53\">\n            <div class=\"&quot;space-y-4&quot;\" data-kid=\"54\">\n              <div class=\"&quot;flex\" justify-between text-[10px] font-black text-white uppercase tracking-widest data-kid=\"55\">\n                <span data-kid=\"56\">Adjust Growth Rate</span>\n                <span class=\"&quot;text-white&quot;\" data-kid=\"57\">+15%</span>\n              </div>\n              <input type=\"&quot;range&quot;\" value=\"&quot;45&quot;\" data-kid=\"58\">\n            </div>\n            <button class=\"&quot;btn-primary\" w-full data-kid=\"59\">Run Simulation</button>\n          </div>\n        </div>\n      </aside>\n\n      \n      <div class=\"&quot;lg:col-span-8\" space-y-8 data-kid=\"60\">\n        \n        <div class=\"&quot;grid\" md:grid-cols-2 gap-8 data-kid=\"61\">\n          <div class=\"&quot;glass-card\" p-10 flex flex-col items-center justify-center text-center relative overflow-hidden data-kid=\"62\">\n            <div class=\"&quot;absolute\" inset-0 bg-white blur-[80px] rounded-full data-kid=\"63\"></div>\n            <div class=\"&quot;relative&quot;\" data-kid=\"64\">\n              <p class=\"&quot;text-[10px]\" font-black uppercase tracking-[0.4em] text-white mb-2 data-kid=\"65\">Current Index</p>\n              <h2 class=\"&quot;font-display\" font-black text-8xl tabular-nums text-white data-kid=\"66\">68</h2>\n              <div class=\"&quot;mt-4\" inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white border border-white data-kid=\"67\">\n                <span class=\"&quot;text-[10px]\" font-black text-white uppercase tracking-widest data-kid=\"68\">Baseline</span>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"&quot;glass-card\" p-10 flex flex-col items-center justify-center text-center relative overflow-hidden border-t-gold data-kid=\"69\">\n            <div class=\"&quot;absolute\" inset-0 bg-[#D4AF37] blur-[80px] rounded-full data-kid=\"70\"></div>\n            <div class=\"&quot;relative&quot;\" data-kid=\"71\">\n              <p class=\"&quot;text-[10px]\" font-black uppercase tracking-[0.4em] text-[#D4AF37] mb-2 data-kid=\"72\">Simulated Index</p>\n              <h2 class=\"&quot;font-display\" font-black text-8xl tabular-nums text-[#D4AF37] text-glow-gold data-kid=\"73\">82</h2>\n              <div class=\"&quot;mt-4\" inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#4ade80] border border-[#4ade80] data-kid=\"74\">\n                <i class=\"&quot;ti\" ti-arrow-up-right text-[#4ade80] data-kid=\"75\"></i>\n                <span class=\"&quot;text-[10px]\" font-black text-[#4ade80] uppercase tracking-widest data-kid=\"76\">+14 Delta</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"&quot;glass-card\" p-10 space-y-8 data-kid=\"77\">\n          <div class=\"&quot;flex\" justify-between items-end data-kid=\"78\">\n            <div data-kid=\"79\">\n              <p class=\"&quot;text-[10px]\" font-black uppercase tracking-[0.4em] text-white mb-2 data-kid=\"80\">Growth Trajectory</p>\n              <h3 class=\"&quot;text-2xl\" font-black data-kid=\"81\">Net Worth Projection (2026—2036)</h3>\n            </div>\n            <div class=\"&quot;text-right&quot;\" data-kid=\"82\">\n              <p class=\"&quot;text-[10px]\" font-black uppercase tracking-[0.4em] text-[#D4AF37] mb-1 data-kid=\"83\">Estimated Liquidity</p>\n              <p class=\"&quot;font-display\" font-black text-3xl tabular-nums data-kid=\"84\">₹4.8<span class=\"&quot;text-sm\" ml-1 opacity-30 data-kid=\"85\">Cr</span></p>\n            </div>\n          </div>\n          \n          <div class=\"&quot;h-[300px]\" w-full relative mt-8 data-kid=\"86\">\n            <canvas id=\"&quot;trajectoryChart&quot;\" data-kid=\"87\"></canvas>\n          </div>\n        </div>\n\n        \n        <div class=\"&quot;grid\" md:grid-cols-3 gap-6 data-kid=\"88\">\n          <div class=\"&quot;glass-card\" p-6 border-l-4 border-teal-500 data-kid=\"89\">\n            <p class=\"&quot;text-[10px]\" font-black uppercase tracking-widest text-teal-500 mb-2 data-kid=\"90\">DTI Ratio</p>\n            <p class=\"&quot;font-display\" font-black text-2xl tabular-nums data-kid=\"91\">12.5%</p>\n            <p class=\"&quot;text-[9px]\" font-bold text-white uppercase mt-2 data-kid=\"92\">-8.2% Reduction</p>\n          </div>\n          <div class=\"&quot;glass-card\" p-6 border-l-4 border-[#D4AF37] data-kid=\"93\">\n            <p class=\"&quot;text-[10px]\" font-black uppercase tracking-widest text-[#D4AF37] mb-2 data-kid=\"94\">Savings Rate</p>\n            <p class=\"&quot;font-display\" font-black text-2xl tabular-nums data-kid=\"95\">38.0%</p>\n            <p class=\"&quot;text-[9px]\" font-bold text-white uppercase mt-2 data-kid=\"96\">+12.0% Increase</p>\n          </div>\n          <div class=\"&quot;glass-card\" p-6 border-l-4 border-white data-kid=\"97\">\n            <p class=\"&quot;text-[10px]\" font-black uppercase tracking-widest text-white mb-2 data-kid=\"98\">Safe Withdrawal</p>\n            <p class=\"&quot;font-display\" font-black text-2xl tabular-nums data-kid=\"99\">₹1.2L</p>\n            <p class=\"&quot;text-[9px]\" font-bold text-white uppercase mt-2 data-kid=\"100\">Monthly Baseline</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </main>\n</div>\n\n<script src=\"&quot;https://cdn.jsdelivr.net/npm/chart.js&quot;\" data-kid=\"101\"></script>\n<script data-kid=\"102\">\n  const ctx = document.getElementById('trajectoryChart').getContext('2d');\n  \n  const gradient = ctx.createLinearGradient(0, 0, 0, 300);\n  gradient.addColorStop(0, 'rgba(212, 175, 55, 0.3)');\n  gradient.addColorStop(1, 'rgba(212, 175, 55, 0)');\n\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['2026', '2028', '2030', '2032', '2034', '2036'],\n      datasets: [\n        {\n          label: 'Simulated Path',\n          data: [0.5, 1.2, 2.1, 3.4, 4.2, 4.8],\n          borderColor: '#D4AF37',\n          borderWidth: 4,\n          pointRadius: 0,\n          tension: 0.4,\n          fill: true,\n          backgroundColor: gradient\n        },\n        {\n          label: 'Current Path',\n          data: [0.5, 0.8, 1.1, 1.5, 1.8, 2.2],\n          borderColor: 'rgba(255, 255, 255, 0.1)',\n          borderWidth: 2,\n          borderDash: [5, 5],\n          pointRadius: 0,\n          tension: 0.4,\n          fill: false\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false }\n      },\n      scales: {\n        x: {\n          grid: { display: false },\n          ticks: { color: 'rgba(255, 255, 255, 0.2)', font: { size: 10, weight: 'bold' } }\n        },\n        y: {\n          grid: { color: 'rgba(255, 255, 255, 0.05)' },\n          ticks: { \n            color: 'rgba(255, 255, 255, 0.2)', \n            font: { size: 10, weight: 'bold' },\n            callback: value => '₹' + value + 'Cr'\n          }\n        }\n      }\n    }\n  });\n</script>",
