      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --gold: #D4AF37;\n    --gold-glow: rgba(212, 175, 55, 0.4);\n    --blue: #4F8EF7;\n    --green: #31C48D;\n    --bg-black: #000000;\n    --glass: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg-black);\n    color: #ffffff;\n    font-family: 'Instrument Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  h1, h2, h3, .font-display {\n    font-family: 'Cabinet Grotesk', sans-serif;\n    letter-spacing: -0.02em;\n  }\n\n  .glass-card {\n    background: linear-gradient(145deg, rgba(20, 20, 20, 0.4) 0%, rgba(10, 10, 10, 0.6) 100%);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n    border-top: 1px solid rgba(255, 255, 255, 0.12);\n    border-left: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n    border-radius: 24px;\n    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .glass-card:hover {\n    transform: translateY(-4px);\n    border-top: 1px solid var(--gold);\n    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), inset 0 1px 1px var(--gold-glow);\n  }\n\n  .radial-video-mask {\n    mask-image: radial-gradient(circle at 50% 50%, black 20%, transparent 80%);\n    -webkit-mask-image: radial-gradient(circle at 50% 50%, black 20%, transparent 80%);\n  }\n\n  /* Custom Range Input Styling */\n  input[type=range] {\n    -webkit-appearance: none;\n    width: 100%;\n    background: transparent;\n  }\n\n  input[type=range]:focus {\n    outline: none;\n  }\n\n  input[type=range]::-webkit-slider-runnable-track {\n    width: 100%;\n    height: 4px;\n    cursor: pointer;\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 2px;\n  }\n\n  input[type=range]::-webkit-slider-thumb {\n    height: 20px;\n    width: 20px;\n    border-radius: 50%;\n    background: #fff;\n    cursor: pointer;\n    -webkit-appearance: none;\n    margin-top: -8px;\n    box-shadow: 0 0 15px currentColor;\n  }\n\n  .slider-gold::-webkit-slider-thumb { color: var(--gold); background: var(--gold); }\n  .slider-blue::-webkit-slider-thumb { color: var(--blue); background: var(--blue); }\n  .slider-green::-webkit-slider-thumb { color: var(--green); background: var(--green); }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .floating {\n    animation: float 4s ease-in-out infinite;\n  }\n\n  .donut-container svg {\n    filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.2));\n  }\n</style>\n\n<div class=\"min-h-screen relative overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"absolute inset-0 z-0\" data-kid=\"2\">\n    <video src=\"https://videos.pexels.com/video-files/30248506/12967486_640_360_30fps.mp4\" autoplay muted loop playsinline class=\"w-full h-full object-cover radial-video-mask opacity-30\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\"></video>\n    <div class=\"absolute inset-0 bg-gradient-to-b from-black via-transparent to-black\" data-kid=\"4\"></div>\n    <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#D4AF37]/5 blur-[120px] rounded-full pointer-events-none\" data-kid=\"5\"></div>\n  </div>\n\n  <div class=\"relative z-10 container mx-auto px-12 py-24\" data-kid=\"6\">\n    \n    <div class=\"mb-20 text-center\" data-kid=\"7\">\n      <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#D4AF37]/10 border border-[#D4AF37]/20 mb-6\" data-kid=\"8\">\n        <span class=\"w-1.5 h-1.5 rounded-full bg-[#D4AF37] animate-pulse\" data-kid=\"9\"></span>\n        <span class=\"text-[10px] font-black uppercase tracking-widest text-[#D4AF37]\" data-kid=\"10\">Algorithmic Budgeting</span>\n      </div>\n      <h1 class=\"text-6xl font-black tracking-tighter mb-4\" data-kid=\"11\">50/30/20 Command</h1>\n      <p class=\"text-white/40 text-lg max-w-2xl mx-auto font-medium\" data-kid=\"12\">\n        Precision-engineered resource allocation. Balance your essentials, lifestyle, and future wealth with institutional accuracy.\n      </p>\n    </div>\n\n    <div class=\"grid lg:grid-cols-12 gap-12 items-center\" data-kid=\"13\">\n      \n      <div class=\"lg:col-span-4 space-y-8\" data-kid=\"14\">\n        <div class=\"glass-card p-8\" data-kid=\"15\">\n          <div class=\"flex justify-between items-center mb-6\" data-kid=\"16\">\n            <h3 class=\"text-sm font-black uppercase tracking-widest text-white/60\" data-kid=\"17\">Target Allocation</h3>\n            <i class=\"ti ti-adjustments-horizontal text-[#D4AF37] text-xl\" data-kid=\"18\"></i>\n          </div>\n          \n          <div class=\"space-y-10\" data-kid=\"19\">\n            <div class=\"space-y-4\" data-kid=\"20\">\n              <div class=\"flex justify-between items-end\" data-kid=\"21\">\n                <span class=\"text-xs font-bold uppercase tracking-widest text-white/40\" data-kid=\"22\">🏠 Needs</span>\n                <span class=\"font-display font-black text-2xl text-[#D4AF37]\" id=\"val-needs\" data-kid=\"23\">50%</span>\n              </div>\n              <input type=\"range\" min=\"5\" max=\"90\" value=\"50\" class=\"slider-gold\" id=\"input-needs\" data-kid=\"24\">\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"25\">\n              <div class=\"flex justify-between items-end\" data-kid=\"26\">\n                <span class=\"text-xs font-bold uppercase tracking-widest text-white/40\" data-kid=\"27\">🎉 Wants</span>\n                <span class=\"font-display font-black text-2xl text-[#blue]\" id=\"val-wants\" data-kid=\"28\">30%</span>\n              </div>\n              <input type=\"range\" min=\"5\" max=\"90\" value=\"30\" class=\"slider-blue\" id=\"input-wants\" data-kid=\"29\">\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"30\">\n              <div class=\"flex justify-between items-end\" data-kid=\"31\">\n                <span class=\"text-xs font-bold uppercase tracking-widest text-white/40\" data-kid=\"32\">💰 Savings</span>\n                <span class=\"font-display font-black text-2xl text-[#green]\" id=\"val-savings\" data-kid=\"33\">20%</span>\n              </div>\n              <input type=\"range\" min=\"5\" max=\"90\" value=\"20\" class=\"slider-green\" id=\"input-savings\" data-kid=\"34\">\n            </div>\n          </div>\n        </div>\n\n        <div class=\"glass-card p-6 flex items-center gap-6\" data-kid=\"35\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center\" data-kid=\"36\">\n            <i class=\"ti ti-cash text-2xl text-white/40\" data-kid=\"37\"></i>\n          </div>\n          <div data-kid=\"38\">\n            <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest mb-1\" data-kid=\"39\">Monthly Liquidity</p>\n            <p class=\"font-display font-black text-2xl\" data-kid=\"40\">₹85,000</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-4 flex justify-center\" data-kid=\"41\">\n        <div class=\"relative donut-container floating\" data-kid=\"42\">\n          <svg width=\"360\" height=\"360\" viewBox=\"0 0 100 100\" data-kid=\"43\">\n            <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"transparent\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"12\" data-kid=\"44\"></circle>\n            <circle id=\"arc-needs\" cx=\"50\" cy=\"50\" r=\"40\" fill=\"transparent\" stroke=\"var(--gold)\" stroke-width=\"12\" stroke-dasharray=\"0 251.2\" stroke-dashoffset=\"0\" transform=\"rotate(-90 50 50)\" style=\"transition: stroke-dasharray 0.6s cubic-bezier(0.2, 0.8, 0.2, 1)\" data-kid=\"45\"></circle>\n            <circle id=\"arc-wants\" cx=\"50\" cy=\"50\" r=\"40\" fill=\"transparent\" stroke=\"var(--blue)\" stroke-width=\"12\" stroke-dasharray=\"0 251.2\" stroke-dashoffset=\"0\" transform=\"rotate(-90 50 50)\" style=\"transition: stroke-dasharray 0.6s cubic-bezier(0.2, 0.8, 0.2, 1)\" data-kid=\"46\"></circle>\n            <circle id=\"arc-savings\" cx=\"50\" cy=\"50\" r=\"40\" fill=\"transparent\" stroke=\"var(--green)\" stroke-width=\"12\" stroke-dasharray=\"0 251.2\" stroke-dashoffset=\"0\" transform=\"rotate(-90 50 50)\" style=\"transition: stroke-dasharray 0.6s cubic-bezier(0.2, 0.8, 0.2, 1)\" data-kid=\"47\"></circle>\n          </svg>\n          <div class=\"absolute inset-0 flex flex-col items-center justify-center text-center\" data-kid=\"48\">\n            <p class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.3em] mb-2\" data-kid=\"49\">Total Score</p>\n            <span class=\"font-display font-black text-7xl text-glow-gold\" data-kid=\"50\">100</span>\n            <p class=\"text-[10px] font-black text-[#D4AF37] uppercase tracking-widest mt-2 border border-[#D4AF37]/30 px-3 py-1 rounded-full\" data-kid=\"51\">Optimized</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-4 space-y-6\" data-kid=\"52\">\n        <h3 class=\"text-sm font-black uppercase tracking-widest text-white/60 mb-4 px-2\" data-kid=\"53\">Priority Breakdown</h3>\n        <div class=\"grid grid-cols-2 gap-4\" data-kid=\"54\">\n          <div class=\"glass-card p-5\" data-kid=\"55\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"56\">\n              <i class=\"ti ti-home text-[#D4AF37]\" data-kid=\"57\"></i>\n              <span class=\"text-[9px] font-black text-white/30 uppercase\" data-kid=\"58\">Rent</span>\n            </div>\n            <p class=\"font-display font-bold text-lg mb-2\" data-kid=\"59\">₹22.5k</p>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"60\">\n              <div class=\"w-[65%] h-full bg-[#D4AF37]\" data-kid=\"61\"></div>\n            </div>\n          </div>\n          \n          <div class=\"glass-card p-5\" data-kid=\"62\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"63\">\n              <i class=\"ti ti-building-bank text-[#D4AF37]\" data-kid=\"64\"></i>\n              <span class=\"text-[9px] font-black text-white/30 uppercase\" data-kid=\"65\">EMI</span>\n            </div>\n            <p class=\"font-display font-bold text-lg mb-2\" data-kid=\"66\">₹18.5k</p>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"67\">\n              <div class=\"w-[45%] h-full bg-[#D4AF37]\" data-kid=\"68\"></div>\n            </div>\n          </div>\n\n          <div class=\"glass-card p-5\" data-kid=\"69\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"70\">\n              <i class=\"ti ti-shopping-cart text-[#D4AF37]\" data-kid=\"71\"></i>\n              <span class=\"text-[9px] font-black text-white/30 uppercase\" data-kid=\"72\">Groceries</span>\n            </div>\n            <p class=\"font-display font-bold text-lg mb-2\" data-kid=\"73\">₹8.2k</p>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"74\">\n              <div class=\"w-[80%] h-full bg-[#D4AF37]\" data-kid=\"75\"></div>\n            </div>\n          </div>\n\n          <div class=\"glass-card p-5\" data-kid=\"76\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"77\">\n              <i class=\"ti ti-bolt text-[#D4AF37]\" data-kid=\"78\"></i>\n              <span class=\"text-[9px] font-black text-white/30 uppercase\" data-kid=\"79\">Utilities</span>\n            </div>\n            <p class=\"font-display font-bold text-lg mb-2\" data-kid=\"80\">₹4.1k</p>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"81\">\n              <div class=\"w-[30%] h-full bg-[#D4AF37]\" data-kid=\"82\"></div>\n            </div>\n          </div>\n\n          <div class=\"lg:col-span-2 glass-card p-5 flex items-center justify-between\" data-kid=\"83\">\n            <div class=\"flex items-center gap-4\" data-kid=\"84\">\n              <div class=\"w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center\" data-kid=\"85\">\n                <i class=\"ti ti-leaf text-green-500\" data-kid=\"86\"></i>\n              </div>\n              <p class=\"text-xs font-bold text-white/60\" data-kid=\"87\">Investment Potential</p>\n            </div>\n            <p class=\"font-display font-black text-xl text-green-500\" data-kid=\"88\">+₹17k</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script data-kid=\"89\">\n  const inputs = {\n    needs: document.getElementById('input-needs'),\n    wants: document.getElementById('input-wants'),\n    savings: document.getElementById('input-savings')\n  };\n\n  const values = {\n    needs: document.getElementById('val-needs'),\n    wants: document.getElementById('val-wants'),\n    savings: document.getElementById('val-savings')\n  };\n\n  const arcs = {\n    needs: document.getElementById('arc-needs'),\n    wants: document.getElementById('arc-wants'),\n    savings: document.getElementById('arc-savings')\n  };\n\n  function update() {\n    const n = parseInt(inputs.needs.value);\n    const w = parseInt(inputs.wants.value);\n    const s = parseInt(inputs.savings.value);\n    \n    values.needs.innerText = n + '%';\n    values.wants.innerText = w + '%';\n    values.savings.innerText = s + '%';\n\n    const circumference = 2 * Math.PI * 40;\n    \n    const dashNeeds = (n / 100) * circumference;\n    const dashWants = (w / 100) * circumference;\n    const dashSavings = (s / 100) * circumference;\n\n    arcs.needs.style.strokeDasharray = `${dashNeeds} ${circumference}`;\n    arcs.needs.style.strokeDashoffset = 0;\n\n    arcs.wants.style.strokeDasharray = `${dashWants} ${circumference}`;\n    arcs.wants.style.strokeDashoffset = -dashNeeds;\n\n    arcs.savings.style.strokeDasharray = `${dashSavings} ${circumference}`;\n    arcs.savings.style.strokeDashoffset = -(dashNeeds + dashWants);\n  }\n\n  function handleSlider(key, val) {\n    const clamped = Math.max(5, Math.min(90, val));\n    const remaining = 100 - clamped;\n    \n    const others = Object.keys(inputs).filter(k => k !== key);\n    const currentOthersSum = others.reduce((sum, k) => sum + parseInt(inputs[k].value), 0);\n\n    let a, b;\n    if (currentOthersSum === 0) {\n      a = Math.floor(remaining / 2);\n      b = remaining - a;\n    } else {\n      const p1 = parseInt(inputs[others[0]].value);\n      a = Math.round((p1 / currentOthersSum) * remaining);\n      a = Math.min(Math.max(a, 5), remaining - 5);\n      b = remaining - a;\n    }\n\n    inputs[key].value = clamped;\n    inputs[others[0]].value = a;\n    inputs[others[1]].value = b;\n    \n    update();\n  }\n\n  inputs.needs.oninput = (e) => handleSlider('needs', parseInt(e.target.value));\n  inputs.wants.oninput = (e) => handleSlider('wants', parseInt(e.target.value));\n  inputs.savings.oninput = (e) => handleSlider('savings', parseInt(e.target.value));\n\n  update();\n</script>",
