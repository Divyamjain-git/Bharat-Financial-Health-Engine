      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --gold: #D4AF37;\n    --black: #000000;\n    --white: #FFFFFF;\n    --border: rgba(255, 255, 255, 0.15);\n  }\n\n  .font-display { font-family: 'Cabinet Grotesk', sans-serif; }\n  .font-body { font-family: 'Instrument Sans', sans-serif; }\n\n  .hero-headline {\n    font-size: clamp(80px, 12vw, 160px);\n    line-height: 0.85;\n    letter-spacing: -0.04em;\n    font-weight: 900;\n  }\n\n  .ledger-row {\n    transition: all 0.2s ease-in-out;\n  }\n\n  .ledger-row:hover {\n    background-color: var(--white);\n    color: var(--black);\n  }\n\n  .ledger-row:hover .text-gold {\n    color: var(--black) !important;\n  }\n\n  .corner-bracket::before {\n    content: '⌜';\n    position: absolute;\n    top: 0;\n    left: 0;\n    font-size: 24px;\n    color: var(--gold);\n  }\n\n  .corner-bracket::after {\n    content: '⌝';\n    position: absolute;\n    top: 0;\n    right: 0;\n    font-size: 24px;\n    color: var(--gold);\n  }\n\n  .duotone-gold {\n    filter: sepia(1) saturate(5) hue-rotate(-10deg) brightness(0.8) contrast(1.2);\n  }\n\n  .editorial-column {\n    column-count: 1;\n    text-align: justify;\n    hyphens: auto;\n  }\n</style>\n\n<div class=\"bg-black text-white font-body min-h-screen selection:bg-[#D4AF37] selection:text-black\" data-kid=\"1\">\n  \n  <nav class=\"flex items-center justify-between px-10 py-8 border-b border-[var(--border)]\" data-kid=\"2\">\n    <div class=\"flex items-center gap-12\" data-kid=\"3\">\n      <div class=\"font-display font-extrabold text-2xl tracking-tighter\" data-kid=\"4\">BFHE.</div>\n      <div class=\"hidden lg:flex gap-8 text-[11px] font-bold tracking-[0.2em] uppercase text-white/50\" data-kid=\"5\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"6\">The Engine</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"7\">Data Integrity</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"8\">Institutional</a>\n      </div>\n    </div>\n    <div class=\"flex items-center gap-8 text-[11px] font-bold tracking-[0.2em] uppercase\" data-kid=\"9\">\n      <a href=\"#\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"10\">Access Portal</a>\n      <a href=\"#\" class=\"px-6 py-3 border border-white hover:bg-white hover:text-black transition-all\" data-kid=\"11\">Request Entry</a>\n    </div>\n  </nav>\n\n  \n  <section class=\"grid grid-cols-1 lg:grid-cols-[300px_1fr] border-b border-[var(--border)]\" data-kid=\"12\">\n    \n    <div class=\"border-r border-[var(--border)] p-10 flex flex-col justify-between gap-20\" data-kid=\"13\">\n      <div class=\"space-y-12\" data-kid=\"14\">\n        <div class=\"space-y-2\" data-kid=\"15\">\n          <div class=\"text-[10px] font-black uppercase tracking-[0.3em] text-[var(--gold)]\" data-kid=\"16\">Volume 01.</div>\n          <div class=\"text-sm font-medium leading-relaxed text-white/60 italic\" data-kid=\"17\">Architecting the future of wealth preservation in the Indian subcontinent.</div>\n        </div>\n        <div class=\"space-y-4\" data-kid=\"18\">\n          <div class=\"h-px bg-[var(--border)] w-full\" data-kid=\"19\"></div>\n          <div class=\"flex justify-between text-[9px] font-bold tracking-[0.2em] uppercase text-white/40\" data-kid=\"20\">\n            <span data-kid=\"21\">Market Status</span>\n            <span class=\"text-white\" data-kid=\"22\">Active</span>\n          </div>\n          <div class=\"flex justify-between text-[9px] font-bold tracking-[0.2em] uppercase text-white/40\" data-kid=\"23\">\n            <span data-kid=\"24\">Location</span>\n            <span class=\"text-white\" data-kid=\"25\">Mumbai, IN</span>\n          </div>\n          <div class=\"flex justify-between text-[9px] font-bold tracking-[0.2em] uppercase text-white/40\" data-kid=\"26\">\n            <span data-kid=\"27\">Update Frequency</span>\n            <span class=\"text-white\" data-kid=\"28\">Real-time</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"29\">\n        <p class=\"text-xs text-white/50 leading-loose\" data-kid=\"30\">\n          A definitive collection of financial tools designed for the modern professional. Secured by bank-grade encryption and powered by proprietary AI models.\n        </p>\n        <div class=\"text-[var(--gold)] font-display font-bold text-lg\" data-kid=\"31\">01 // 2026</div>\n      </div>\n    </div>\n\n    \n    <div class=\"relative\" data-kid=\"32\">\n      <div class=\"p-10 lg:p-20 space-y-10\" data-kid=\"33\">\n        <h1 class=\"hero-headline font-display\" data-kid=\"34\">\n          THE NEW<br data-kid=\"35\">\n          STANDARD<br data-kid=\"36\">\n          OF <span class=\"text-[var(--gold)]\" data-kid=\"37\">WEALTH.</span>\n        </h1>\n        \n        <div class=\"relative mt-20\" data-kid=\"38\">\n          <img src=\"https://images.unsplash.com/photo-1620122830785-a18b43585b44?auto=format&w=1200&q=80&fit=crop\" alt=\"Corporate Professional\" class=\"w-full grayscale contrast-125 brightness-75 object-cover h-[600px]\" decoding=\"async\" loading=\"lazy\" data-kid=\"39\">\n          \n          \n          <div class=\"absolute -bottom-10 -left-6 lg:left-12 bg-white text-black p-8 lg:p-12 shadow-2xl max-w-sm\" data-kid=\"40\">\n            <div class=\"text-[10px] font-black uppercase tracking-[0.3em] mb-4 opacity-40\" data-kid=\"41\">Live Financial Score</div>\n            <div class=\"font-display font-black text-7xl lg:text-8xl tracking-tighter leading-none mb-4\" data-kid=\"42\">84.2</div>\n            <div class=\"space-y-4\" data-kid=\"43\">\n              <p class=\"text-sm font-semibold uppercase tracking-widest leading-tight\" data-kid=\"44\">Elite Tier Status Confirmed</p>\n              <div class=\"h-1 bg-black/10 w-full overflow-hidden\" data-kid=\"45\">\n                <div class=\"h-full bg-black w-[84%]\" data-kid=\"46\"></div>\n              </div>\n              <p class=\"text-[10px] leading-relaxed opacity-60\" data-kid=\"47\">Top 2% of salaried professionals in the tech sector. Insights calculated against 42 distinct market vectors.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24\" data-kid=\"48\">\n    <div class=\"px-10 mb-12 flex justify-between items-end\" data-kid=\"49\">\n      <div class=\"space-y-2\" data-kid=\"50\">\n        <div class=\"text-[10px] font-black uppercase tracking-[0.3em] text-[var(--gold)]\" data-kid=\"51\">The Ledger.</div>\n        <h2 class=\"font-display font-black text-5xl\" data-kid=\"52\">Engine Components</h2>\n      </div>\n      <div class=\"text-xs text-white/40 tracking-widest uppercase mb-2\" data-kid=\"53\">[ Select item to expand ]</div>\n    </div>\n\n    <div class=\"border-t border-[var(--border)]\" data-kid=\"54\">\n      {[\n        { id: '01', title: 'Algorithmic Budgeting', desc: 'Neural-net categorization of cash flow across 150+ merchant types.' },\n        { id: '02', title: 'Asset Allocation', desc: 'Real-time rebalancing suggestions for multi-asset portfolios including digital assets.' },\n        { id: '03', title: 'Debt Liquidation Engine', desc: 'Snowball and avalanche simulations optimized for the Indian interest rate cycle.' },\n        { id: '04', title: 'Tax Strategy Optimization', desc: 'Advanced modeling for 80C, 80D, and bespoke high-net-worth tax scenarios.' }\n      ].map((item) => (\n        <div class=\"ledger-row border-b border-[var(--border)] px-10 py-12 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-8 cursor-pointer group\" data-kid=\"55\">\n          <div class=\"flex items-center gap-12 lg:gap-20\" data-kid=\"56\">\n            <span class=\"font-display font-bold text-lg text-[var(--gold)] transition-colors duration-200\" data-kid=\"57\">{item.id}</span>\n            <h3 class=\"font-display font-extrabold text-3xl lg:text-4xl tracking-tight transition-colors duration-200\" data-kid=\"58\">{item.title}</h3>\n          </div>\n          <div class=\"flex items-center gap-12 max-w-md\" data-kid=\"59\">\n            <p class=\"text-sm opacity-50 transition-colors duration-200 leading-relaxed\" data-kid=\"60\">{item.desc}</p>\n            <i class=\"ti ti-plus text-2xl opacity-30 group-hover:rotate-45 transition-transform duration-300\" data-kid=\"61\"></i>\n          </div>\n        </div>\n      ))}\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-10 bg-white text-black\" data-kid=\"62\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-0\" data-kid=\"63\">\n      <div class=\"p-12 relative border-r border-black/10 corner-bracket\" data-kid=\"64\">\n        <div class=\"font-display font-black text-6xl mb-8 leading-none\" data-kid=\"65\">₹10K Cr+</div>\n        <div class=\"editorial-column font-semibold text-sm leading-relaxed uppercase tracking-wider\" data-kid=\"66\">\n          Assets currently monitored across our high-security infrastructure. We maintain absolute discretion and data sovereignty for every institutional and private client.\n        </div>\n      </div>\n      <div class=\"p-12 relative border-r border-black/10 corner-bracket\" data-kid=\"67\">\n        <div class=\"font-display font-black text-6xl mb-8 leading-none\" data-kid=\"68\">1.2M+</div>\n        <div class=\"editorial-column font-semibold text-sm leading-relaxed uppercase tracking-wider\" data-kid=\"69\">\n          Daily data points ingested by the engine to ensure that your financial health score is reflective of current market volatility and inflationary pressures.\n        </div>\n      </div>\n      <div class=\"p-12 relative corner-bracket\" data-kid=\"70\">\n        <div class=\"font-display font-black text-6xl mb-8 leading-none\" data-kid=\"71\">ZERO</div>\n        <div class=\"editorial-column font-semibold text-sm leading-relaxed uppercase tracking-wider\" data-kid=\"72\">\n          Compromises made on encryption. Our zero-knowledge proof architecture ensures that your private financial records remain solely under your control.\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"pt-32 pb-16 px-10\" data-kid=\"73\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-24 mb-32\" data-kid=\"74\">\n      <div class=\"flex items-start gap-12\" data-kid=\"75\">\n        <div class=\"relative flex-shrink-0\" data-kid=\"76\">\n          <img src=\"https://images.unsplash.com/photo-1627401632925-a4c565d08a80?auto=format&w=800&q=80&fit=crop\" alt=\"Portrait\" class=\"w-32 h-32 object-cover duotone-gold\" decoding=\"async\" loading=\"lazy\" data-kid=\"77\">\n          <div class=\"absolute -top-2 -left-2 w-full h-full border border-[var(--gold)]/30\" data-kid=\"78\"></div>\n        </div>\n        <blockquote class=\"space-y-6\" data-kid=\"79\">\n          <p class=\"font-body italic text-2xl lg:text-3xl text-white/80 leading-relaxed\" data-kid=\"80\">\n            \"BFHE has transformed the way I visualize my future. It's not just an app; it's an intellectual companion for my wealth journey.\"\n          </p>\n          <cite class=\"block font-display font-bold text-lg not-italic\" data-kid=\"81\">— Sanjay K., Director of Engineering</cite>\n        </blockquote>\n      </div>\n\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-12\" data-kid=\"82\">\n        <div class=\"space-y-6\" data-kid=\"83\">\n          <h4 class=\"text-[9px] font-black uppercase tracking-[0.3em] text-[var(--gold)]\" data-kid=\"84\">Navigation</h4>\n          <ul class=\"space-y-4 text-xs font-bold tracking-widest uppercase text-white/40\" data-kid=\"85\">\n            <li data-kid=\"86\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"87\">Index</a></li>\n            <li data-kid=\"88\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"89\">Archive</a></li>\n            <li data-kid=\"90\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"91\">Dossier</a></li>\n          </ul>\n        </div>\n        <div class=\"space-y-6\" data-kid=\"92\">\n          <h4 class=\"text-[9px] font-black uppercase tracking-[0.3em] text-[var(--gold)]\" data-kid=\"93\">Legal</h4>\n          <ul class=\"space-y-4 text-xs font-bold tracking-widest uppercase text-white/40\" data-kid=\"94\">\n            <li data-kid=\"95\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"96\">Privacy</a></li>\n            <li data-kid=\"97\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"98\">Terms</a></li>\n            <li data-kid=\"99\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"100\">Data</a></li>\n          </ul>\n        </div>\n        <div class=\"space-y-6\" data-kid=\"101\">\n          <h4 class=\"text-[9px] font-black uppercase tracking-[0.3em] text-[var(--gold)]\" data-kid=\"102\">Connect</h4>\n          <ul class=\"space-y-4 text-xs font-bold tracking-widest uppercase text-white/40\" data-kid=\"103\">\n            <li data-kid=\"104\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"105\">Terminal</a></li>\n            <li data-kid=\"106\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"107\">Support</a></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"flex flex-col lg:flex-row justify-between items-center pt-12 border-t border-[var(--border)] gap-8\" data-kid=\"108\">\n      <div class=\"flex items-center gap-6\" data-kid=\"109\">\n        <div class=\"font-display font-black text-xl tracking-tighter\" data-kid=\"110\">BFHE.</div>\n        <span class=\"text-[9px] font-bold tracking-[0.3em] text-white/20 uppercase\" data-kid=\"111\">All rights reserved © 2026</span>\n      </div>\n      <div class=\"flex items-center gap-12 text-[9px] font-bold tracking-[0.3em] text-white/20 uppercase\" data-kid=\"112\">\n        <span data-kid=\"113\">EN // Global</span>\n        <span class=\"text-white/40\" data-kid=\"114\">Status: Secure</span>\n        <span data-kid=\"115\">Mumbai / Bangalore / London</span>\n      </div>\n    </div>\n  </footer>\n</div>",
