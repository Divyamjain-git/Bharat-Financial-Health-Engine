      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --gold: #D4AF37;\n    --gold-glow: rgba(212, 175, 55, 0.4);\n    --bg-black: #000000;\n    --glass: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n    --teal: #2DD4BF;\n  }\n\n  body {\n    background-color: var(--bg-black);\n    color: #ffffff;\n    font-family: 'Instrument Sans', sans-serif;\n    margin: 0;\n    display: flex;\n    min-height: 100vh;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  h1, h2, h3, .font-display {\n    font-family: 'Cabinet Grotesk', sans-serif;\n    letter-spacing: -0.02em;\n  }\n\n  .glass-card {\n    background: linear-gradient(145deg, rgba(20, 20, 20, 0.4) 0%, rgba(10, 10, 10, 0.6) 100%);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n    border-top: 1px solid rgba(255, 255, 255, 0.12);\n    border-left: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n    border-radius: 24px;\n    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .glass-card:hover {\n    transform: translateY(-4px);\n    border-top: 1px solid var(--gold);\n    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), inset 0 1px 1px var(--gold-glow);\n  }\n\n  .sidebar {\n    width: 280px;\n    background: rgba(5, 5, 5, 0.8);\n    border-right: 1px solid var(--glass-border);\n    backdrop-filter: blur(40px);\n    height: 100vh;\n    position: sticky;\n    top: 0;\n    padding: 40px 24px;\n    display: flex;\n    flex-direction: column;\n    z-index: 100;\n  }\n\n  .main-content {\n    flex: 1;\n    padding: 40px 48px;\n    max-width: calc(1440px - 280px);\n    margin: 0 auto;\n    width: 100%;\n  }\n\n  .text-glow-gold {\n    text-shadow: 0 0 20px var(--gold-glow);\n  }\n\n  .floating {\n    animation: float 4s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .nav-item {\n    padding: 12px 16px;\n    border-radius: 12px;\n    color: rgba(255,255,255,0.4);\n    font-weight: 700;\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    transition: all 0.2s;\n  }\n\n  .nav-item:hover, .nav-item.active {\n    background: rgba(255,255,255,0.05);\n    color: white;\n  }\n\n  .nav-item.active {\n    color: var(--gold);\n    border-left: 3px solid var(--gold);\n    border-radius: 0 12px 12px 0;\n    background: linear-gradient(90deg, rgba(212, 175, 55, 0.1) 0%, transparent 100%);\n  }\n\n  .score-orb-container {\n    position: relative;\n    width: 400px;\n    height: 400px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .score-orb-glow {\n    position: absolute;\n    inset: -40px;\n    background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);\n    filter: blur(40px);\n    pointer-events: none;\n  }\n\n  .badge-elite {\n    background: rgba(45, 212, 191, 0.1);\n    border: 1px solid rgba(45, 212, 191, 0.2);\n    color: var(--teal);\n    padding: 4px 12px;\n    border-radius: 99px;\n    font-size: 10px;\n    font-weight: 900;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n  }\n\n  .grid-pattern {\n    background-image: radial-gradient(rgba(212, 175, 55, 0.1) 1px, transparent 1px);\n    background-size: 30px 30px;\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    z-index: -1;\n  }\n\n  /* Custom Chart Simulation */\n  .chart-bar {\n    width: 10px;\n    background: var(--gold);\n    border-radius: 4px 4px 0 0;\n    transition: height 1s ease-out;\n  }\n</style>\n\n<div class=\"grid-pattern\" data-kid=\"1\"></div>\n\n<aside class=\"sidebar\" data-kid=\"2\">\n  <div class=\"flex items-center gap-3 mb-12\" data-kid=\"3\">\n    <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#D4AF37] to-[#b8860b] flex items-center justify-center font-black text-black text-xl\" data-kid=\"4\">₹</div>\n    <span class=\"font-display font-black text-2xl tracking-tighter\" data-kid=\"5\">BFHE</span>\n  </div>\n  \n  <nav class=\"flex-1 space-y-2\" data-kid=\"6\">\n    <a href=\"#\" class=\"nav-item active\" data-kid=\"7\"><i class=\"ti ti-layout-dashboard\" data-kid=\"8\"></i> Dashboard</a>\n    <a href=\"#\" class=\"nav-item\" data-kid=\"9\"><i class=\"ti ti-chart-pie\" data-kid=\"10\"></i> Net Worth</a>\n    <a href=\"#\" class=\"nav-item\" data-kid=\"11\"><i class=\"ti ti-wallet\" data-kid=\"12\"></i> Budgeting</a>\n    <a href=\"#\" class=\"nav-item\" data-kid=\"13\"><i class=\"ti ti-target\" data-kid=\"14\"></i> Goals</a>\n    <a href=\"#\" class=\"nav-item\" data-kid=\"15\"><i class=\"ti ti-cpu\" data-kid=\"16\"></i> Simulator</a>\n  </nav>\n\n  <div class=\"mt-auto pt-8 border-t border-white/5\" data-kid=\"17\">\n    <div class=\"flex items-center gap-3 glass-card p-4\" data-kid=\"18\">\n      <img src=\"https://i.pravatar.cc/100?u=arjun\" class=\"w-10 h-10 rounded-full border border-white/10\" alt=\"Arjun\" data-kid=\"19\">\n      <div data-kid=\"20\">\n        <p class=\"text-xs font-bold\" data-kid=\"21\">Arjun Sharma</p>\n        <p class=\"text-[10px] text-white/40 uppercase tracking-widest font-black\" data-kid=\"22\">Elite Member</p>\n      </div>\n    </div>\n  </div>\n</aside>\n\n<main class=\"main-content\" data-kid=\"23\">\n  \n  <header class=\"flex items-center justify-between mb-12\" data-kid=\"24\">\n    <div data-kid=\"25\">\n      <h1 class=\"text-3xl font-black tracking-tight mb-1\" data-kid=\"26\">Good morning, Arjun.</h1>\n      <p class=\"text-sm text-white/40 font-medium\" data-kid=\"27\">Your financial engine is operating at peak efficiency.</p>\n    </div>\n    <div class=\"flex items-center gap-4\" data-kid=\"28\">\n      <div class=\"relative\" data-kid=\"29\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/20\" data-kid=\"30\"></i>\n        <input type=\"text\" placeholder=\"Command Search...\" class=\"bg-white/5 border border-white/10 rounded-xl py-3 pl-12 pr-6 text-sm focus:outline-none focus:border-gold/50 transition-all\" data-kid=\"31\">\n      </div>\n      <button class=\"w-12 h-12 glass-card flex items-center justify-center relative\" data-kid=\"32\">\n        <i class=\"ti ti-bell\" data-kid=\"33\"></i>\n        <span class=\"absolute top-3 right-3 w-2 h-2 bg-red-500 rounded-full\" data-kid=\"34\"></span>\n      </button>\n    </div>\n  </header>\n\n  \n  <div class=\"grid grid-cols-4 gap-6 mb-12\" data-kid=\"35\">\n    <div class=\"glass-card p-6\" data-kid=\"36\">\n      <p class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.2em] mb-3\" data-kid=\"37\">Monthly Income</p>\n      <h2 class=\"text-2xl font-black font-display tabular-nums\" data-kid=\"38\">₹85,000</h2>\n      <div class=\"mt-4 flex items-center gap-2\" data-kid=\"39\">\n        <span class=\"text-[10px] text-teal-500 font-bold\" data-kid=\"40\"><i class=\"ti ti-trending-up\" data-kid=\"41\"></i> +4.2%</span>\n        <span class=\"text-[10px] text-white/20 uppercase font-black tracking-widest\" data-kid=\"42\">vs Last Month</span>\n      </div>\n    </div>\n    <div class=\"glass-card p-6\" data-kid=\"43\">\n      <p class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.2em] mb-3\" data-kid=\"44\">Total EMI</p>\n      <h2 class=\"text-2xl font-black font-display tabular-nums\" data-kid=\"45\">₹18,500</h2>\n      <div class=\"mt-4 flex items-center gap-2\" data-kid=\"46\">\n        <span class=\"text-[10px] text-gold font-bold\" data-kid=\"47\">21.7%</span>\n        <span class=\"text-[10px] text-white/20 uppercase font-black tracking-widest\" data-kid=\"48\">DTI Ratio</span>\n      </div>\n    </div>\n    <div class=\"glass-card p-6\" data-kid=\"49\">\n      <p class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.2em] mb-3\" data-kid=\"50\">Savings Rate</p>\n      <h2 class=\"text-2xl font-black font-display tabular-nums\" data-kid=\"51\">19.4%</h2>\n      <div class=\"mt-4 flex items-center gap-2\" data-kid=\"52\">\n        <span class=\"text-[10px] text-teal-500 font-bold\" data-kid=\"53\">Excellent</span>\n        <span class=\"text-[10px] text-white/20 uppercase font-black tracking-widest\" data-kid=\"54\">Tier</span>\n      </div>\n    </div>\n    <div class=\"glass-card p-6\" data-kid=\"55\">\n      <p class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.2em] mb-3\" data-kid=\"56\">Net Worth</p>\n      <h2 class=\"text-2xl font-black font-display tabular-nums\" data-kid=\"57\">₹12.4L</h2>\n      <div class=\"mt-4 flex items-center gap-2\" data-kid=\"58\">\n        <span class=\"text-[10px] text-teal-500 font-bold\" data-kid=\"59\"><i class=\"ti ti-trending-up\" data-kid=\"60\"></i> +₹24k</span>\n        <span class=\"text-[10px] text-white/20 uppercase font-black tracking-widest\" data-kid=\"61\">This week</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"grid grid-cols-3 gap-8 items-start\" data-kid=\"62\">\n    \n    \n    <div class=\"col-span-1 flex flex-col items-center\" data-kid=\"63\">\n      <div class=\"score-orb-container mb-8\" data-kid=\"64\">\n        <div class=\"score-orb-glow\" data-kid=\"65\"></div>\n        <div class=\"glass-card rounded-full w-[340px] h-[340px] flex flex-col items-center justify-center text-center floating\" data-kid=\"66\">\n          <svg class=\"absolute inset-0 w-full h-full -rotate-90 scale-[0.82]\" data-kid=\"67\">\n            <circle cx=\"50%\" cy=\"50%\" r=\"45%\" fill=\"none\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"12\" stroke-linecap=\"round\" data-kid=\"68\"></circle>\n            <circle cx=\"50%\" cy=\"50%\" r=\"45%\" fill=\"none\" stroke=\"url(#orbGradient)\" stroke-width=\"12\" stroke-dasharray=\"240 283\" stroke-linecap=\"round\" class=\"score-arc\" data-kid=\"69\"></circle>\n            <defs data-kid=\"70\">\n              <linearGradient id=\"orbGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\" data-kid=\"71\">\n                <stop offset=\"0%\" stop-color=\"#D4AF37\" data-kid=\"72\"></stop>\n                <stop offset=\"100%\" stop-color=\"#F5D76E\" data-kid=\"73\"></stop>\n              </linearGradient>\n            </defs>\n          </svg>\n          <div class=\"relative z-10\" data-kid=\"74\">\n            <span class=\"font-display font-black text-[120px] text-glow-gold tabular-nums leading-none\" data-kid=\"75\">85</span>\n            <p class=\"text-sm font-black uppercase tracking-[0.4em] text-gold mt-2\" data-kid=\"76\">Health Score</p>\n            <div class=\"mt-6\" data-kid=\"77\">\n              <span class=\"badge-elite\" data-kid=\"78\">Elite Tier</span>\n            </div>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"glass-card p-6 w-full\" data-kid=\"79\">\n        <h3 class=\"text-xs font-black uppercase tracking-[0.2em] text-white/40 mb-6\" data-kid=\"80\">Component Analysis</h3>\n        <div class=\"space-y-4\" data-kid=\"81\">\n          <div class=\"flex justify-between items-center text-xs\" data-kid=\"82\">\n            <span class=\"font-bold text-white/60\" data-kid=\"83\">Debt-to-Income</span>\n            <span class=\"font-black text-gold\" data-kid=\"84\">92/100</span>\n          </div>\n          <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"85\">\n            <div class=\"w-[92%] h-full bg-gold\" data-kid=\"86\"></div>\n          </div>\n          \n          <div class=\"flex justify-between items-center text-xs\" data-kid=\"87\">\n            <span class=\"font-bold text-white/60\" data-kid=\"88\">Savings Rate</span>\n            <span class=\"font-black text-teal-500\" data-kid=\"89\">78/100</span>\n          </div>\n          <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"90\">\n            <div class=\"w-[78%] h-full bg-teal-500\" data-kid=\"91\"></div>\n          </div>\n\n          <div class=\"flex justify-between items-center text-xs\" data-kid=\"92\">\n            <span class=\"font-bold text-white/60\" data-kid=\"93\">Emergency Fund</span>\n            <span class=\"font-black text-red-500\" data-kid=\"94\">45/100</span>\n          </div>\n          <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"95\">\n            <div class=\"w-[45%] h-full bg-red-500\" data-kid=\"96\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-2 grid grid-cols-2 gap-8\" data-kid=\"97\">\n      \n      \n      <div class=\"col-span-2 glass-card p-8\" data-kid=\"98\">\n        <div class=\"flex justify-between items-center mb-8\" data-kid=\"99\">\n          <h3 class=\"text-xl font-black tracking-tight\" data-kid=\"100\">Net Worth Velocity</h3>\n          <div class=\"flex gap-2\" data-kid=\"101\">\n            <button class=\"text-[10px] font-black uppercase tracking-widest px-3 py-1 bg-white/5 rounded-md\" data-kid=\"102\">6M</button>\n            <button class=\"text-[10px] font-black uppercase tracking-widest px-3 py-1 text-gold\" data-kid=\"103\">1Y</button>\n          </div>\n        </div>\n        <div class=\"h-48 relative\" data-kid=\"104\">\n          \n          <svg class=\"w-full h-full\" viewBox=\"0 0 800 200\" preserveAspectRatio=\"none\" data-kid=\"105\">\n            <defs data-kid=\"106\">\n              <linearGradient id=\"areaGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" data-kid=\"107\">\n                <stop offset=\"0%\" stop-color=\"var(--teal)\" stop-opacity=\"0.3\" data-kid=\"108\"></stop>\n                <stop offset=\"100%\" stop-color=\"var(--teal)\" stop-opacity=\"0\" data-kid=\"109\"></stop>\n              </linearGradient>\n            </defs>\n            <path d=\"M0,180 Q100,160 200,170 T400,130 T600,100 T800,80 L800,200 L0,200 Z\" fill=\"url(#areaGradient)\" data-kid=\"110\"></path>\n            <path d=\"M0,180 Q100,160 200,170 T400,130 T600,100 T800,80\" fill=\"none\" stroke=\"var(--teal)\" stroke-width=\"3\" data-kid=\"111\"></path>\n          </svg>\n          <div class=\"absolute bottom-0 left-0 right-0 flex justify-between text-[9px] font-black text-white/20 uppercase tracking-widest mt-4\" data-kid=\"112\">\n            <span data-kid=\"113\">Jan</span><span data-kid=\"114\">Mar</span><span data-kid=\"115\">May</span><span data-kid=\"116\">Jul</span><span data-kid=\"117\">Sep</span><span data-kid=\"118\">Nov</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-8\" data-kid=\"119\">\n        <h3 class=\"text-sm font-black uppercase tracking-[0.2em] text-white/40 mb-8\" data-kid=\"120\">Monthly Outflow</h3>\n        <div class=\"flex items-center gap-8\" data-kid=\"121\">\n          <div class=\"relative w-24 h-24\" data-kid=\"122\">\n            <svg class=\"w-full h-full -rotate-90\" data-kid=\"123\">\n              <circle cx=\"50%\" cy=\"50%\" r=\"40%\" fill=\"none\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"8\" data-kid=\"124\"></circle>\n              <circle cx=\"50%\" cy=\"50%\" r=\"40%\" fill=\"none\" stroke=\"#D4AF37\" stroke-width=\"8\" stroke-dasharray=\"125 251\" stroke-linecap=\"round\" data-kid=\"125\"></circle>\n            </svg>\n            <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"126\">\n              <span class=\"text-xs font-black\" data-kid=\"127\">50%</span>\n              <span class=\"text-[8px] text-white/40 font-black uppercase\" data-kid=\"128\">Needs</span>\n            </div>\n          </div>\n          <div class=\"space-y-3\" data-kid=\"129\">\n            <div class=\"flex items-center gap-2\" data-kid=\"130\">\n              <div class=\"w-2 h-2 rounded-full bg-gold\" data-kid=\"131\"></div>\n              <span class=\"text-xs font-bold text-white/60\" data-kid=\"132\">Rent & EMI</span>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"133\">\n              <div class=\"w-2 h-2 rounded-full bg-white/40\" data-kid=\"134\"></div>\n              <span class=\"text-xs font-bold text-white/60\" data-kid=\"135\">Lifestyle</span>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"136\">\n              <div class=\"w-2 h-2 rounded-full bg-teal-500\" data-kid=\"137\"></div>\n              <span class=\"text-xs font-bold text-white/60\" data-kid=\"138\">Savings</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-8\" data-kid=\"139\">\n        <h3 class=\"text-sm font-black uppercase tracking-[0.2em] text-white/40 mb-6\" data-kid=\"140\">Priority Goals</h3>\n        <div class=\"space-y-4\" data-kid=\"141\">\n          <div class=\"glass-card bg-white/5 p-3 flex items-center justify-between border-none\" data-kid=\"142\">\n            <div class=\"flex items-center gap-3\" data-kid=\"143\">\n              <span class=\"text-xl\" data-kid=\"144\">🏠</span>\n              <div data-kid=\"145\">\n                <p class=\"text-[10px] font-bold\" data-kid=\"146\">Home Downpayment</p>\n                <div class=\"w-24 h-1 bg-white/10 rounded-full mt-1\" data-kid=\"147\">\n                  <div class=\"w-[65%] h-full bg-gold\" data-kid=\"148\"></div>\n                </div>\n              </div>\n            </div>\n            <span class=\"text-xs font-black text-gold\" data-kid=\"149\">65%</span>\n          </div>\n          <div class=\"glass-card bg-white/5 p-3 flex items-center justify-between border-none\" data-kid=\"150\">\n            <div class=\"flex items-center gap-3\" data-kid=\"151\">\n              <span class=\"text-xl\" data-kid=\"152\">🚗</span>\n              <div data-kid=\"153\">\n                <p class=\"text-[10px] font-bold\" data-kid=\"154\">New SUV Fund</p>\n                <div class=\"w-24 h-1 bg-white/10 rounded-full mt-1\" data-kid=\"155\">\n                  <div class=\"w-[22%] h-full bg-teal-500\" data-kid=\"156\"></div>\n                </div>\n              </div>\n            </div>\n            <span class=\"text-xs font-black text-teal-500\" data-kid=\"157\">22%</span>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"158\"></script>\n<script data-kid=\"159\">\n  // Simple hover animation for cards using GSAP\n  document.querySelectorAll('.glass-card').forEach(card => {\n    card.addEventListener('mouseenter', () => {\n      gsap.to(card, { scale: 1.02, duration: 0.3, ease: 'power2.out' });\n    });\n    card.addEventListener('mouseleave', () => {\n      gsap.to(card, { scale: 1, duration: 0.3, ease: 'power2.out' });\n    });\n  });\n</script>",
