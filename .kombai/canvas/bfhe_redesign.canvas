      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --gold: #D4AF37;\n    --gold-glow: rgba(212, 175, 55, 0.4);\n    --bg-navy: #050810;\n    --border-glass: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: #000000;\n    color: #ffffff;\n    font-family: 'Instrument Sans', sans-serif;\n    overflow-x: hidden;\n  }\n\n  .font-display {\n    font-family: 'Cabinet Grotesk', sans-serif;\n  }\n\n  .tracking-spatial {\n    letter-spacing: 0.15em;\n  }\n\n  .glass-surface {\n    background: linear-gradient(145deg, rgba(20, 24, 35, 0.4) 0%, rgba(5, 8, 16, 0.6) 100%);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border-glass);\n    border-top: 1px solid rgba(255, 255, 255, 0.15);\n  }\n\n  .vignette {\n    box-shadow: inset 0 0 150px rgba(0,0,0,0.9);\n  }\n\n  .isometric-cascade {\n    perspective: 2000px;\n    transform-style: preserve-3d;\n  }\n\n  .iso-panel {\n    transform: rotateX(45deg) rotateZ(-35deg) translateY(0);\n    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .emerald-glow {\n    filter: drop-shadow(0 0 15px rgba(74, 222, 128, 0.4));\n  }\n\n  /* Custom scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #000;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--gold);\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"relative w-full overflow-hidden\" data-kid=\"1\">\n  \n  <nav class=\"fixed top-0 left-0 w-full z-50 px-10 py-6 flex justify-between items-center mix-blend-difference\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-8 h-8 rounded-lg bg-[var(--gold)] flex items-center justify-center font-black text-black text-sm\" data-kid=\"4\">₹</div>\n      <span class=\"font-display font-black tracking-widest text-lg\" data-kid=\"5\">BFHE</span>\n    </div>\n    <div class=\"flex gap-8 items-center\" data-kid=\"6\">\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-widest text-white/50 hover:text-white transition-colors uppercase\" data-kid=\"7\">Philosophy</a>\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-widest text-white/50 hover:text-white transition-colors uppercase\" data-kid=\"8\">Engine</a>\n      <a href=\"#\" class=\"text-[11px] font-bold tracking-widest text-white/50 hover:text-white transition-colors uppercase\" data-kid=\"9\">Access</a>\n      <button class=\"px-6 py-2 border border-white/10 rounded-full text-[10px] font-bold tracking-[0.2em] uppercase hover:bg-white hover:text-black transition-all\" data-kid=\"10\">Sign In</button>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative min-h-screen flex flex-col items-center pt-40 pb-20 overflow-hidden\" data-kid=\"11\">\n    \n    <div class=\"absolute top-1/4 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] bg-blue-900/10 rounded-full blur-[120px] pointer-events-none\" data-kid=\"12\"></div>\n\n    <div class=\"relative z-10 text-center max-w-4xl px-10 mb-24\" data-kid=\"13\">\n      <div class=\"inline-block px-4 py-1.5 border border-[var(--gold)]/20 rounded-full mb-8 bg-[var(--gold)]/5\" data-kid=\"14\">\n        <span class=\"text-[10px] font-black tracking-[0.3em] text-[var(--gold)] uppercase\" data-kid=\"15\">A Spatial Finance Experiment</span>\n      </div>\n      <h1 class=\"font-display text-7xl md:text-8xl font-black tracking-spatial leading-none mb-10 text-white\" data-kid=\"16\">\n        YOUR FINANCIAL <br data-kid=\"17\"> TRUTH, AUGMENTED.\n      </h1>\n      <p class=\"text-white/40 text-lg max-w-2xl mx-auto leading-relaxed\" data-kid=\"18\">\n        Experience the physical manifestation of your wealth. BFHE renders complex fiscal data into a tactile, holographic ledger for the modern sovereign professional.\n      </p>\n      \n      <div class=\"mt-12 flex items-center justify-center gap-6\" data-kid=\"19\">\n        <button class=\"group relative px-10 py-5 bg-[var(--gold)] text-black font-black tracking-[0.2em] text-xs uppercase overflow-hidden transition-all\" data-kid=\"20\">\n          <span class=\"relative z-10\" data-kid=\"21\">Initialize Connection</span>\n          <div class=\"absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300\" data-kid=\"22\"></div>\n        </button>\n        <button class=\"px-10 py-5 border border-white/10 text-white font-black tracking-[0.2em] text-xs uppercase hover:bg-white/5 transition-all\" data-kid=\"23\">\n          Explore the Vault\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"relative w-full h-[600px] mt-20 isometric-cascade pointer-events-none\" data-kid=\"24\">\n      \n      <div class=\"iso-panel absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] glass-surface rounded-2xl p-2 shadow-2xl opacity-80\" style=\"z-index: 1;\" data-kid=\"25\">\n        <img src=\"https://images.unsplash.com/photo-1666875753105-c63a6f3bdc86?auto=format&w=1280&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-xl\" decoding=\"async\" loading=\"lazy\" alt=\"BFHE Interface\" data-kid=\"26\">\n      </div>\n      \n      \n      <div class=\"iso-panel absolute top-[50px] left-[60%] w-[300px] h-[300px] glass-surface rounded-2xl p-8 flex flex-col justify-center items-center shadow-[0_20px_50px_rgba(0,0,0,0.5)] border-t-[var(--gold)]/30\" style=\"z-index: 3; transform: rotateX(45deg) rotateZ(-35deg) translateZ(150px);\" data-kid=\"27\">\n        <div class=\"font-display text-[var(--gold)] text-8xl font-black leading-none\" data-kid=\"28\">85</div>\n        <div class=\"text-[10px] font-bold tracking-[0.4em] text-white/40 uppercase mt-4\" data-kid=\"29\">Health Index</div>\n        <div class=\"w-full h-1 bg-white/5 rounded-full mt-10 overflow-hidden\" data-kid=\"30\">\n          <div class=\"w-[85%] h-full bg-[var(--gold)] shadow-[0_0_15px_var(--gold-glow)]\" data-kid=\"31\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"iso-panel absolute top-[300px] left-[35%] w-[240px] glass-surface rounded-xl p-6 shadow-xl\" style=\"z-index: 4; transform: rotateX(45deg) rotateZ(-35deg) translateZ(250px);\" data-kid=\"32\">\n        <div class=\"flex items-center gap-4\" data-kid=\"33\">\n          <div class=\"w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-400\" data-kid=\"34\">\n            <i class=\"ti ti-trending-up text-xl\" data-kid=\"35\"></i>\n          </div>\n          <div data-kid=\"36\">\n            <div class=\"text-[10px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"37\">Growth</div>\n            <div class=\"text-xl font-bold\" data-kid=\"38\">+12.4%</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"walkthrough\" class=\"relative py-40\" data-kid=\"39\">\n    \n    <div class=\"step-container relative min-h-[80vh] flex items-center px-20 mb-40\" data-kid=\"40\">\n      <div class=\"w-1/2 sticky top-1/4 h-fit pr-20\" data-kid=\"41\">\n        <div class=\"text-[var(--gold)] font-black tracking-[0.4em] text-[10px] uppercase mb-6\" data-kid=\"42\">01 / Perspective</div>\n        <h2 class=\"font-display text-6xl font-black tracking-spatial leading-tight text-white mb-8\" data-kid=\"43\">\n          DECIPHER <br data-kid=\"44\">YOUR DEBT.\n        </h2>\n        <p class=\"text-white/40 text-lg leading-relaxed mb-10\" data-kid=\"45\">\n          The engine disassembles your liabilities into interactive 3D structures. Understand the weight of each commitment and simulate its erasure with holographic precision.\n        </p>\n      </div>\n      <div class=\"w-1/2 h-[600px] relative\" data-kid=\"46\">\n        <div class=\"absolute inset-0 glass-surface rounded-3xl overflow-hidden shadow-2xl\" data-kid=\"47\">\n          <div class=\"p-12 h-full flex flex-col\" data-kid=\"48\">\n            <div class=\"flex justify-between items-center mb-12\" data-kid=\"49\">\n              <span class=\"text-xs font-bold tracking-widest text-white/20 uppercase\" data-kid=\"50\">Liability Matrix</span>\n              <div class=\"flex gap-2\" data-kid=\"51\">\n                <div class=\"w-2 h-2 rounded-full bg-red-500/40\" data-kid=\"52\"></div>\n                <div class=\"w-2 h-2 rounded-full bg-yellow-500/40\" data-kid=\"53\"></div>\n                <div class=\"w-2 h-2 rounded-full bg-green-500/40\" data-kid=\"54\"></div>\n              </div>\n            </div>\n            <div class=\"flex-1 flex items-end gap-6 px-10\" data-kid=\"55\">\n              <div class=\"flex-1 bg-white/5 rounded-t-xl transition-all duration-700 h-[40%] hover:h-[60%] hover:bg-[var(--gold)]/20 relative group\" data-kid=\"56\">\n                 <div class=\"absolute -top-10 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-[10px] font-bold\" data-kid=\"57\">EMI</div>\n              </div>\n              <div class=\"flex-1 bg-white/5 rounded-t-xl transition-all duration-700 h-[70%] hover:h-[90%] hover:bg-[var(--gold)]/20 relative group\" data-kid=\"58\"></div>\n              <div class=\"flex-1 bg-white/5 rounded-t-xl transition-all duration-700 h-[30%] hover:h-[50%] hover:bg-[var(--gold)]/20 relative group\" data-kid=\"59\"></div>\n              <div class=\"flex-1 bg-white/5 rounded-t-xl transition-all duration-700 h-[85%] hover:h-[100%] hover:bg-[var(--gold)]/20 relative group\" data-kid=\"60\"></div>\n              <div class=\"flex-1 bg-white/5 rounded-t-xl transition-all duration-700 h-[55%] hover:h-[75%] hover:bg-[var(--gold)]/20 relative group\" data-kid=\"61\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"step-container relative min-h-[80vh] flex flex-row-reverse items-center px-20 mb-40\" data-kid=\"62\">\n      <div class=\"w-1/2 sticky top-1/4 h-fit pl-20\" data-kid=\"63\">\n        <div class=\"text-emerald-400 font-black tracking-[0.4em] text-[10px] uppercase mb-6\" data-kid=\"64\">02 / Projection</div>\n        <h2 class=\"font-display text-6xl font-black tracking-spatial leading-tight text-white mb-8\" data-kid=\"65\">\n          GROW WITH <br data-kid=\"66\">PRECISION.\n        </h2>\n        <p class=\"text-white/40 text-lg leading-relaxed mb-10\" data-kid=\"67\">\n          Our emerald projection line cuts through market noise. Watch your net worth trajectory respond to real-time adjustments in your investment engine.\n        </p>\n      </div>\n      <div class=\"w-1/2 h-[600px] relative\" data-kid=\"68\">\n        <div class=\"absolute inset-0 glass-surface rounded-3xl overflow-hidden shadow-2xl flex items-center justify-center\" data-kid=\"69\">\n          <svg viewBox=\"0 0 800 400\" class=\"w-full h-full p-20 emerald-glow\" data-kid=\"70\">\n            <path d=\"M 0 350 Q 150 350, 300 250 T 600 100 T 800 50\" fill=\"none\" stroke=\"#4ade80\" stroke-width=\"4\" stroke-linecap=\"round\" data-kid=\"71\"></path>\n            <circle cx=\"600\" cy=\"100\" r=\"8\" fill=\"#4ade80\" data-kid=\"72\"></circle>\n            <text x=\"620\" y=\"90\" fill=\"#4ade80\" font-size=\"14\" font-weight=\"bold\" font-family=\"Cabinet Grotesk\" data-kid=\"73\">₹2.4 Cr</text>\n            <path d=\"M 0 350 L 800 350\" stroke=\"rgba(255,255,255,0.05)\" stroke-dasharray=\"10 10\" data-kid=\"74\"></path>\n          </svg>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"step-container relative min-h-[80vh] flex items-center px-20\" data-kid=\"75\">\n      <div class=\"w-1/2 sticky top-1/4 h-fit pr-20\" data-kid=\"76\">\n        <div class=\"text-[var(--gold)] font-black tracking-[0.4em] text-[10px] uppercase mb-6\" data-kid=\"77\">03 / Automation</div>\n        <h2 class=\"font-display text-6xl font-black tracking-spatial leading-tight text-white mb-8\" data-kid=\"78\">\n          AUTOMATE THE <br data-kid=\"79\">MUNDANE.\n        </h2>\n        <p class=\"text-white/40 text-lg leading-relaxed mb-10\" data-kid=\"80\">\n          The engine's clockwork never stops. While you focus on high-leverage decisions, the BFHE background processes continuously optimize your cash flows and tax structures.\n        </p>\n      </div>\n      <div class=\"w-1/2 h-[600px] relative\" data-kid=\"81\">\n        <div class=\"absolute inset-0 glass-surface rounded-3xl overflow-hidden shadow-2xl\" data-kid=\"82\">\n          <video src=\"https://videos.pexels.com/video-files/33212388/14153619_360_640_60fps.mp4\" poster=\"https://images.pexels.com/videos/33212388/3d-3d-render-3d-rendering-animation-33212388.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-60\" data-kid=\"83\"></video>\n          <div class=\"absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent\" data-kid=\"84\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-40 px-20\" data-kid=\"85\">\n    <div class=\"text-center mb-32\" data-kid=\"86\">\n       <h2 class=\"font-display text-4xl md:text-5xl font-black tracking-spatial leading-tight text-white mb-6 uppercase\" data-kid=\"87\">\n        The Financial Engine\n      </h2>\n      <p class=\"text-white/30 text-sm tracking-[0.2em] uppercase font-bold\" data-kid=\"88\">Technical Specifications v4.2.0</p>\n    </div>\n\n    <div class=\"relative max-w-5xl mx-auto h-[600px] flex items-center justify-center\" data-kid=\"89\">\n      \n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/mesh-network.svg\" class=\"w-full h-full opacity-10 absolute pointer-events-none\" style=\"filter: invert(1) sepia(1) saturate(5) hue-rotate(10deg);\" alt=\"Data Pipeline\" data-kid=\"90\">\n      \n      \n      <div class=\"absolute top-10 left-10 p-6 glass-surface rounded-xl max-w-[200px] hover:border-[var(--gold)] transition-all cursor-crosshair\" data-kid=\"91\">\n        <div class=\"text-[10px] font-mono text-[var(--gold)] mb-2\" data-kid=\"92\">0x1_CAT</div>\n        <div class=\"text-sm font-bold mb-1\" data-kid=\"93\">AI Categorization</div>\n        <p class=\"text-[10px] text-white/40 leading-relaxed\" data-kid=\"94\">99.8% precision in mapping multi-bank transaction data.</p>\n      </div>\n\n      <div class=\"absolute bottom-20 right-0 p-6 glass-surface rounded-xl max-w-[200px] hover:border-[var(--gold)] transition-all cursor-crosshair\" data-kid=\"95\">\n        <div class=\"text-[10px] font-mono text-emerald-400 mb-2\" data-kid=\"96\">0x2_TAX</div>\n        <div class=\"text-sm font-bold mb-1\" data-kid=\"97\">Predictive Tax Modeling</div>\n        <p class=\"text-[10px] text-white/40 leading-relaxed\" data-kid=\"98\">Real-time liability estimation for Indian tax slabs.</p>\n      </div>\n\n      <div class=\"absolute top-1/2 right-10 -translate-y-1/2 p-6 glass-surface rounded-xl max-w-[200px] hover:border-[var(--gold)] transition-all cursor-crosshair\" data-kid=\"99\">\n        <div class=\"text-[10px] font-mono text-blue-400 mb-2\" data-kid=\"100\">0x3_INF</div>\n        <div class=\"text-sm font-bold mb-1\" data-kid=\"101\">Inflation Adjustments</div>\n        <p class=\"text-[10px] text-white/40 leading-relaxed\" data-kid=\"102\">Dynamic wealth erosion tracking against current CPI.</p>\n      </div>\n\n      \n      <div class=\"w-40 h-40 rounded-full border border-[var(--gold)]/20 flex items-center justify-center relative\" data-kid=\"103\">\n        <div class=\"w-32 h-32 rounded-full bg-[var(--gold)]/10 animate-pulse flex items-center justify-center\" data-kid=\"104\">\n           <div class=\"w-16 h-16 rounded-full bg-[var(--gold)] shadow-[0_0_50px_var(--gold-glow)]\" data-kid=\"105\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"relative min-h-[80vh] flex flex-col items-center justify-center bg-gradient-to-t from-[#050810] to-black py-40 px-10 vignette overflow-hidden\" data-kid=\"106\">\n    <div class=\"absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\" data-kid=\"107\"></div>\n    \n    <div class=\"text-center relative z-10 max-w-3xl\" data-kid=\"108\">\n      <div class=\"mb-10 flex justify-center\" data-kid=\"109\">\n        <div class=\"w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center text-[var(--gold)] text-3xl\" data-kid=\"110\">\n          <i class=\"ti ti-shield-check\" data-kid=\"111\"></i>\n        </div>\n      </div>\n      <h2 class=\"font-display text-5xl md:text-6xl font-black tracking-spatial leading-tight text-white mb-8 uppercase\" data-kid=\"112\">\n        ENTER THE VAULT.\n      </h2>\n      <p class=\"text-white/40 text-lg mb-12\" data-kid=\"113\">\n        Your data is secured by AES-256 bank-level encryption and held in the strictest sovereignty. Zero tracking. Total clarity.\n      </p>\n      \n      <button class=\"px-16 py-6 bg-[var(--gold)] text-black font-black tracking-[0.3em] text-sm uppercase shadow-[0_0_40px_var(--gold-glow)] hover:scale-105 transition-transform\" data-kid=\"114\">\n        Open Your Account\n      </button>\n\n      <div class=\"mt-20 flex justify-center gap-12 border-t border-white/5 pt-12\" data-kid=\"115\">\n        <div class=\"text-left\" data-kid=\"116\">\n          <div class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.3em] mb-4\" data-kid=\"117\">Location</div>\n          <div class=\"text-xs font-bold text-white/50 uppercase\" data-kid=\"118\">Bengaluru, IN</div>\n        </div>\n        <div class=\"text-left\" data-kid=\"119\">\n          <div class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.3em] mb-4\" data-kid=\"120\">Support</div>\n          <div class=\"text-xs font-bold text-white/50 uppercase\" data-kid=\"121\">engine@bfhe.app</div>\n        </div>\n        <div class=\"text-left\" data-kid=\"122\">\n          <div class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.3em] mb-4\" data-kid=\"123\">Legal</div>\n          <div class=\"text-xs font-bold text-white/50 uppercase\" data-kid=\"124\">Terms of Sovereignty</div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-0 left-0 w-full h-[300px] bg-[url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lord-berandas/diagram.svg')] opacity-[0.02] pointer-events-none bg-repeat\" data-kid=\"125\"></div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"126\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"127\"></script>\n<script type=\"module\" data-kid=\"128\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Register GSAP plugins\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Lenis for smooth scrolling\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n  });\n\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Hero animations\n  gsap.from(\".iso-panel\", {\n    duration: 1.5,\n    y: 100,\n    opacity: 0,\n    stagger: 0.2,\n    ease: \"expo.out\",\n    delay: 0.5\n  });\n\n  // Parallax panels\n  gsap.utils.toArray(\".iso-panel\").forEach((panel, i) => {\n    gsap.to(panel, {\n      y: -50 * (i + 1),\n      scrollTrigger: {\n        trigger: \"section\",\n        start: \"top top\",\n        end: \"bottom top\",\n        scrub: true\n      }\n    });\n  });\n\n  // Step visualizations animations\n  gsap.utils.toArray(\".step-container\").forEach((step) => {\n    const visual = step.querySelector(\".glass-surface\");\n    const text = step.querySelector(\"h2\");\n\n    gsap.from(visual, {\n      x: step.classList.contains(\"flex-row-reverse\") ? -100 : 100,\n      opacity: 0,\n      duration: 1,\n      scrollTrigger: {\n        trigger: step,\n        start: \"top 70%\",\n      }\n    });\n\n    gsap.from(text, {\n      y: 50,\n      opacity: 0,\n      duration: 0.8,\n      scrollTrigger: {\n        trigger: step,\n        start: \"top 70%\",\n      }\n    });\n  });\n\n  // Tooltips float\n  gsap.to(\".glass-surface[hover]\", {\n    y: -10,\n    repeat: -1,\n    yoyo: true,\n    duration: 2,\n    ease: \"sine.inOut\"\n  });\n</script>",
