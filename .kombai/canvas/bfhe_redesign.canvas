      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --gold: #D4AF37;\n    --gold-glow: rgba(212, 175, 55, 0.4);\n    --bg-black: #000000;\n    --glass: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg-black);\n    color: #ffffff;\n    font-family: 'Instrument Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  h1, h2, h3, .font-display {\n    font-family: 'Cabinet Grotesk', sans-serif;\n    letter-spacing: -0.02em;\n  }\n\n  .tabular-nums {\n    font-variant-numeric: tabular-nums;\n  }\n\n  .glass-card {\n    background: linear-gradient(145deg, rgba(20, 20, 20, 0.4) 0%, rgba(10, 10, 10, 0.6) 100%);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n    border-top: 1px solid rgba(255, 255, 255, 0.12);\n    border-left: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n    border-radius: 24px;\n    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .glass-card:hover {\n    transform: translateY(-4px);\n    background: linear-gradient(145deg, rgba(30, 30, 30, 0.5) 0%, rgba(15, 15, 15, 0.7) 100%);\n    border-top: 1px solid var(--gold);\n    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), inset 0 1px 1px var(--gold-glow);\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, var(--gold) 0%, #b8860b 100%);\n    color: #000;\n    font-weight: 800;\n    padding: 16px 32px;\n    border-radius: 12px;\n    transition: all 0.3s ease;\n    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.2);\n  }\n\n  .btn-primary:hover {\n    transform: scale(1.02);\n    box-shadow: 0 10px 40px var(--gold-glow);\n  }\n\n  .text-glow-gold {\n    text-shadow: 0 0 20px var(--gold-glow);\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-15px); }\n  }\n\n  .floating {\n    animation: float 4s ease-in-out infinite;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .animate-marquee {\n    animation: marquee 30s linear infinite;\n  }\n\n  .radial-video-mask {\n    mask-image: radial-gradient(circle at 70% 50%, black 20%, transparent 80%);\n    -webkit-mask-image: radial-gradient(circle at 70% 50%, black 20%, transparent 80%);\n  }\n\n  .grid-pattern {\n    background-image: radial-gradient(rgba(212, 175, 55, 0.1) 1px, transparent 1px);\n    background-size: 30px 30px;\n  }\n\n  .score-arc {\n    stroke-dasharray: 283;\n    stroke-dashoffset: 283;\n    animation: draw 2s ease-out forwards;\n  }\n\n  @keyframes draw {\n    to { stroke-dashoffset: 42; } /* 85% of 283 is ~240, offset is 283-240 = 43 */\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <nav class=\"fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-12 h-20 bg-black/50 backdrop-blur-xl border-b border-white/5\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#D4AF37] to-[#b8860b] flex items-center justify-center font-black text-black text-xl\" data-kid=\"4\">₹</div>\n      <span class=\"font-display font-black text-2xl tracking-tighter\" data-kid=\"5\">BFHE</span>\n    </div>\n    <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"6\">\n      <a href=\"#\" class=\"text-xs font-bold uppercase tracking-widest text-white/50 hover:text-white transition-colors\" data-kid=\"7\">Intelligence</a>\n      <a href=\"#\" class=\"text-xs font-bold uppercase tracking-widest text-white/50 hover:text-white transition-colors\" data-kid=\"8\">Ecosystem</a>\n      <a href=\"#\" class=\"text-xs font-bold uppercase tracking-widest text-white/50 hover:text-white transition-colors\" data-kid=\"9\">Institutional</a>\n      <a href=\"#\" class=\"text-xs font-bold uppercase tracking-widest text-white/50 hover:text-white transition-colors\" data-kid=\"10\">Reserve</a>\n    </div>\n    <div class=\"flex items-center gap-6\" data-kid=\"11\">\n      <button class=\"text-xs font-bold uppercase tracking-widest text-white/70 hover:text-white\" data-kid=\"12\">Access</button>\n      <button class=\"btn-primary text-xs uppercase tracking-widest\" data-kid=\"13\">Reserve Slot</button>\n    </div>\n  </nav>\n\n  \n  <header class=\"relative min-h-screen flex items-center pt-20 overflow-hidden\" data-kid=\"14\">\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"15\">\n      <video src=\"https://videos.pexels.com/video-files/30248506/12967486_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/30248506/pexels-photo-30248506.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover radial-video-mask opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"16\"></video>\n      <div class=\"absolute inset-0 bg-gradient-to-r from-black via-black/40 to-transparent\" data-kid=\"17\"></div>\n    </div>\n\n    <div class=\"relative z-10 container mx-auto px-12 grid lg:grid-cols-2 gap-20 items-center\" data-kid=\"18\">\n      \n      <div data-kid=\"19\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#D4AF37]/10 border border-[#D4AF37]/20 mb-8\" data-kid=\"20\">\n          <span class=\"w-1.5 h-1.5 rounded-full bg-[#D4AF37] animate-pulse\" data-kid=\"21\"></span>\n          <span class=\"text-[10px] font-black uppercase tracking-widest text-[#D4AF37]\" data-kid=\"22\">Engine v4.2 Live</span>\n        </div>\n        <h1 class=\"text-7xl lg:text-8xl font-black leading-[0.9] tracking-tighter mb-8\" data-kid=\"23\">\n          Advance <br data-kid=\"24\">\n          <span class=\"bg-gradient-to-br from-[#D4AF37] to-[#F5D76E] bg-clip-text text-transparent text-glow-gold\" data-kid=\"25\">Your Wealth.</span>\n        </h1>\n        <p class=\"text-xl text-white/50 max-w-lg mb-12 font-medium\" data-kid=\"26\">\n          The ultimate command center for Indian professionals. Decode your financial health with institutional-grade AI.\n        </p>\n        \n        <div class=\"flex flex-col sm:flex-row gap-4 max-w-md\" data-kid=\"27\">\n          <div class=\"relative flex-1\" data-kid=\"28\">\n            <i class=\"ti ti-mail absolute left-5 top-1/2 -translate-y-1/2 text-white/30 text-xl\" data-kid=\"29\"></i>\n            <input type=\"email\" placeholder=\"Professional Email\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-5 pl-14 pr-6 focus:outline-none focus:border-[#D4AF37]/50 text-white placeholder:text-white/20 transition-all backdrop-blur-md\" data-kid=\"30\">\n          </div>\n          <button class=\"btn-primary whitespace-nowrap px-10\" data-kid=\"31\">Get Started</button>\n        </div>\n        \n        <div class=\"mt-10 flex items-center gap-4 text-white/30 text-xs font-bold uppercase tracking-widest\" data-kid=\"32\">\n          <div class=\"flex -space-x-3\" data-kid=\"33\">\n            <img src=\"https://i.pravatar.cc/40?u=1\" class=\"w-8 h-8 rounded-full border-2 border-black\" decoding=\"async\" loading=\"lazy\" data-kid=\"34\">\n            <img src=\"https://i.pravatar.cc/40?u=2\" class=\"w-8 h-8 rounded-full border-2 border-black\" decoding=\"async\" loading=\"lazy\" data-kid=\"35\">\n            <img src=\"https://i.pravatar.cc/40?u=3\" class=\"w-8 h-8 rounded-full border-2 border-black\" decoding=\"async\" loading=\"lazy\" data-kid=\"36\">\n          </div>\n          <span data-kid=\"37\">Trusted by 25k+ Experts</span>\n        </div>\n      </div>\n\n      \n      <div class=\"relative flex justify-center lg:justify-end\" data-kid=\"38\">\n        \n        <div class=\"relative w-[500px] h-[500px] flex items-center justify-center\" data-kid=\"39\">\n          \n          <div class=\"absolute inset-0 bg-[#D4AF37]/10 blur-[120px] rounded-full\" data-kid=\"40\"></div>\n          \n          \n          <div class=\"relative z-10 glass-card p-12 rounded-full w-[420px] h-[420px] flex flex-col items-center justify-center text-center floating\" data-kid=\"41\">\n            <svg class=\"absolute inset-0 w-full h-full -rotate-90 scale-[0.85]\" data-kid=\"42\">\n              <circle cx=\"210\" cy=\"210\" r=\"180\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"12\" fill=\"none\" data-kid=\"43\"></circle>\n              <circle cx=\"210\" cy=\"210\" r=\"180\" stroke=\"#D4AF37\" stroke-width=\"12\" fill=\"none\" class=\"score-arc\" stroke-linecap=\"round\" data-kid=\"44\"></circle>\n            </svg>\n            <div class=\"relative\" data-kid=\"45\">\n              <span class=\"font-display font-black text-9xl text-glow-gold tabular-nums\" data-kid=\"46\">85</span>\n              <p class=\"text-sm font-black uppercase tracking-[0.3em] text-[#D4AF37] mt-2\" data-kid=\"47\">Health Score</p>\n              <div class=\"mt-6 inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-500/10 border border-green-500/20\" data-kid=\"48\">\n                <i class=\"ti ti-trending-up text-green-500\" data-kid=\"49\"></i>\n                <span class=\"text-[10px] font-black text-green-500 uppercase tracking-widest\" data-kid=\"50\">Elite Tier</span>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"absolute top-0 right-0 glass-card p-5 px-7 floating\" style=\"animation-delay: -1s;\" data-kid=\"51\">\n            <p class=\"text-[10px] font-black text-white/40 uppercase tracking-widest mb-1\" data-kid=\"52\">Debt-to-Income</p>\n            <p class=\"font-display font-bold text-2xl tabular-nums text-white\" data-kid=\"53\">12.4<span class=\"text-xs ml-1 text-white/30\" data-kid=\"54\">%</span></p>\n          </div>\n          \n          <div class=\"absolute bottom-10 left-0 glass-card p-5 px-7 floating\" style=\"animation-delay: -2s;\" data-kid=\"55\">\n            <p class=\"text-[10px] font-black text-white/40 uppercase tracking-widest mb-1\" data-kid=\"56\">Liquid Capital</p>\n            <p class=\"font-display font-bold text-2xl tabular-nums text-white\" data-kid=\"57\">₹14.5<span class=\"text-xs ml-1 text-white/30\" data-kid=\"58\">L</span></p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"py-16 bg-white/5 border-y border-white/5 overflow-hidden\" data-kid=\"59\">\n    <div class=\"flex animate-marquee whitespace-nowrap items-center\" data-kid=\"60\">\n      <div class=\"flex items-center gap-24 px-12\" data-kid=\"61\">\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"62\">HDFC BANK</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"63\">ICICI SECURITIES</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"64\">ZERODHA</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"65\">CRED</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"66\">UPSTOX</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"67\">RAZORPAY</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"68\">GROWW</span>\n      </div>\n      <div class=\"flex items-center gap-24 px-12\" data-kid=\"69\">\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"70\">HDFC BANK</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"71\">ICICI SECURITIES</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"72\">ZERODHA</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"73\">CRED</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"74\">UPSTOX</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"75\">RAZORPAY</span>\n        <span class=\"text-2xl font-black text-white/10 font-display tracking-widest\" data-kid=\"76\">GROWW</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 container mx-auto px-12\" data-kid=\"77\">\n    <div class=\"mb-20\" data-kid=\"78\">\n      <p class=\"text-xs font-black text-[#D4AF37] uppercase tracking-[0.4em] mb-4\" data-kid=\"79\">Precision Engineering</p>\n      <h2 class=\"text-5xl font-black tracking-tighter\" data-kid=\"80\">Unified Wealth Architecture.</h2>\n    </div>\n\n    <div class=\"grid lg:grid-cols-3 gap-6 auto-rows-[280px]\" data-kid=\"81\">\n      \n      <div class=\"lg:col-span-2 lg:row-span-2 glass-card p-10 flex flex-col justify-between group overflow-hidden\" data-kid=\"82\">\n        <div data-kid=\"83\">\n          <div class=\"w-12 h-12 rounded-2xl bg-teal-500/10 border border-teal-500/20 flex items-center justify-center mb-6\" data-kid=\"84\">\n            <i class=\"ti ti-trending-up text-teal-500 text-2xl\" data-kid=\"85\"></i>\n          </div>\n          <h3 class=\"text-3xl font-black mb-2\" data-kid=\"86\">Net Worth Tracking</h3>\n          <p class=\"text-white/40 max-w-sm\" data-kid=\"87\">Consolidate FDs, Equities, and Real Estate in a single, high-fidelity ledger.</p>\n        </div>\n        <div class=\"relative h-48 -mb-10 -mx-10 mt-6\" data-kid=\"88\">\n          <svg class=\"w-full h-full\" preserveAspectRatio=\"none\" viewBox=\"0 0 400 100\" data-kid=\"89\">\n            <defs data-kid=\"90\">\n              <linearGradient id=\"chartGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" data-kid=\"91\">\n                <stop offset=\"0%\" stop-color=\"#2dd4bf\" stop-opacity=\"0.3\" data-kid=\"92\"></stop>\n                <stop offset=\"100%\" stop-color=\"#2dd4bf\" stop-opacity=\"0\" data-kid=\"93\"></stop>\n              </linearGradient>\n            </defs>\n            <path d=\"M0 80 Q 50 20, 100 60 T 200 40 T 300 10 T 400 50 V 100 H 0 Z\" fill=\"url(#chartGradient)\" data-kid=\"94\"></path>\n            <path d=\"M0 80 Q 50 20, 100 60 T 200 40 T 300 10 T 400 50\" stroke=\"#2dd4bf\" stroke-width=\"3\" fill=\"none\" data-kid=\"95\"></path>\n          </svg>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-8 flex flex-col justify-between\" data-kid=\"96\">\n        <div class=\"flex justify-between items-start\" data-kid=\"97\">\n          <h3 class=\"text-xl font-black\" data-kid=\"98\">Smart Budgeting</h3>\n          <span class=\"text-[10px] font-black text-[#D4AF37] border border-[#D4AF37]/30 px-2 py-0.5 rounded\" data-kid=\"99\">50/30/20</span>\n        </div>\n        <div class=\"flex items-center gap-6 mt-4\" data-kid=\"100\">\n          <div class=\"relative w-24 h-24\" data-kid=\"101\">\n            <svg class=\"w-full h-full -rotate-90\" data-kid=\"102\">\n              <circle cx=\"48\" cy=\"48\" r=\"40\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"8\" fill=\"none\" data-kid=\"103\"></circle>\n              <circle cx=\"48\" cy=\"48\" r=\"40\" stroke=\"#D4AF37\" stroke-width=\"8\" fill=\"none\" stroke-dasharray=\"251\" stroke-dashoffset=\"125\" data-kid=\"104\"></circle>\n            </svg>\n            <div class=\"absolute inset-0 flex items-center justify-center text-[10px] font-bold text-white/40\" data-kid=\"105\">50%</div>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"106\">\n            <div class=\"flex items-center gap-2\" data-kid=\"107\">\n              <div class=\"w-2 h-2 rounded-full bg-[#D4AF37]\" data-kid=\"108\"></div>\n              <span class=\"text-[10px] font-bold text-white/50 uppercase tracking-widest\" data-kid=\"109\">Needs</span>\n            </div>\n            <div class=\"flex items-center gap-2\" data-kid=\"110\">\n              <div class=\"w-2 h-2 rounded-full bg-white/30\" data-kid=\"111\"></div>\n              <span class=\"text-[10px] font-bold text-white/50 uppercase tracking-widest\" data-kid=\"112\">Wants</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card p-0 overflow-hidden group\" data-kid=\"113\">\n        <div class=\"p-8 absolute inset-0 z-10 flex flex-col justify-end bg-gradient-to-t from-black via-black/40 to-transparent\" data-kid=\"114\">\n          <h3 class=\"text-xl font-black\" data-kid=\"115\">Institutional Trust</h3>\n          <p class=\"text-xs text-white/40 mt-1 uppercase tracking-widest\" data-kid=\"116\">AES-256 Protocol</p>\n        </div>\n        <img src=\"https://images.unsplash.com/photo-1696013910376-c56f76dd8178?auto=format&w=600&q=80&fit=crop\" alt=\"Security Padlock\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"117\">\n      </div>\n\n      \n      <div class=\"lg:col-span-3 glass-card p-8 flex items-center justify-between overflow-hidden relative\" data-kid=\"118\">\n        <div class=\"relative z-10\" data-kid=\"119\">\n          <h3 class=\"text-xl font-black mb-1\" data-kid=\"120\">Adaptive Intelligence</h3>\n          <p class=\"text-white/40 text-sm\" data-kid=\"121\">Real-time alerts for market volatility and score deviations.</p>\n        </div>\n        <div class=\"relative z-10 flex gap-4\" data-kid=\"122\">\n          <div class=\"bg-red-500/10 border border-red-500/20 rounded-xl p-3 px-5 flex items-center gap-3 animate-bounce\" data-kid=\"123\">\n            <i class=\"ti ti-bell-ringing text-red-500\" data-kid=\"124\"></i>\n            <span class=\"text-[10px] font-black text-red-500 uppercase tracking-widest\" data-kid=\"125\">DTI Alert</span>\n          </div>\n          <div class=\"bg-green-500/10 border border-green-500/20 rounded-xl p-3 px-5 flex items-center gap-3\" data-kid=\"126\">\n            <i class=\"ti ti-sparkles text-green-500\" data-kid=\"127\"></i>\n            <span class=\"text-[10px] font-black text-green-500 uppercase tracking-widest\" data-kid=\"128\">Score +2</span>\n          </div>\n        </div>\n        \n        <div class=\"absolute right-0 top-0 bottom-0 w-1/3 bg-gradient-to-l from-[#D4AF37]/5 to-transparent pointer-events-none\" data-kid=\"129\"></div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 relative overflow-hidden grid-pattern border-y border-white/5\" data-kid=\"130\">\n    <div class=\"container mx-auto px-12 grid lg:grid-cols-2 gap-24 items-center\" data-kid=\"131\">\n      <div data-kid=\"132\">\n        <p class=\"text-xs font-black text-[#D4AF37] uppercase tracking-[0.4em] mb-4\" data-kid=\"133\">The Sandbox</p>\n        <h2 class=\"text-5xl font-black tracking-tighter mb-8\" data-kid=\"134\">What-If Engine.</h2>\n        <p class=\"text-lg text-white/50 mb-12\" data-kid=\"135\">Simulate life decisions before they happen. See the trajectory of your wealth across decades in milliseconds.</p>\n        \n        <div class=\"space-y-8 max-w-md\" data-kid=\"136\">\n          <div class=\"space-y-4\" data-kid=\"137\">\n            <div class=\"flex justify-between text-[10px] font-black text-white/40 uppercase tracking-widest\" data-kid=\"138\">\n              <span data-kid=\"139\">Salary Hike</span>\n              <span class=\"text-white\" data-kid=\"140\">+15%</span>\n            </div>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"141\">\n              <div class=\"w-[45%] h-full bg-[#D4AF37]\" data-kid=\"142\"></div>\n            </div>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"143\">\n            <div class=\"flex justify-between text-[10px] font-black text-white/40 uppercase tracking-widest\" data-kid=\"144\">\n              <span data-kid=\"145\">Aggressive Investing</span>\n              <span class=\"text-white\" data-kid=\"146\">Enabled</span>\n            </div>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"147\">\n              <div class=\"w-[80%] h-full bg-[#D4AF37]\" data-kid=\"148\"></div>\n            </div>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"149\">\n            <div class=\"flex justify-between text-[10px] font-black text-white/40 uppercase tracking-widest\" data-kid=\"150\">\n              <span data-kid=\"151\">Home Loan EMI</span>\n              <span class=\"text-white\" data-kid=\"152\">₹45k</span>\n            </div>\n            <div class=\"h-1 bg-white/5 rounded-full overflow-hidden\" data-kid=\"153\">\n              <div class=\"w-[30%] h-full bg-[#D4AF37]\" data-kid=\"154\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"glass-card p-12 h-[500px] flex flex-col justify-between\" data-kid=\"155\">\n        <div class=\"flex justify-between items-start\" data-kid=\"156\">\n          <div data-kid=\"157\">\n            <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest mb-1\" data-kid=\"158\">Projected Outcome (2034)</p>\n            <p class=\"font-display font-black text-4xl tabular-nums\" data-kid=\"159\">₹8.4<span class=\"text-lg ml-1 opacity-40\" data-kid=\"160\">Cr</span></p>\n          </div>\n          <div class=\"text-right\" data-kid=\"161\">\n            <p class=\"text-[10px] font-black text-green-500 uppercase tracking-widest mb-1\" data-kid=\"162\">Score Impact</p>\n            <p class=\"font-display font-black text-2xl text-green-500 tabular-nums\" data-kid=\"163\">+14</p>\n          </div>\n        </div>\n        \n        <div class=\"flex-1 mt-10 relative\" data-kid=\"164\">\n          \n          <svg class=\"w-full h-full\" viewBox=\"0 0 500 200\" data-kid=\"165\">\n            <path d=\"M0 180 Q 100 170, 200 130 T 400 60 T 500 10\" stroke=\"#D4AF37\" stroke-width=\"4\" fill=\"none\" class=\"opacity-80\" stroke-linecap=\"round\" data-kid=\"166\"></path>\n            <path d=\"M0 180 Q 100 175, 200 160 T 400 140 T 500 120\" stroke=\"white\" stroke-opacity=\"0.1\" stroke-width=\"2\" fill=\"none\" stroke-dasharray=\"8 4\" data-kid=\"167\"></path>\n            <circle cx=\"500\" cy=\"10\" r=\"6\" fill=\"#D4AF37\" class=\"animate-pulse\" data-kid=\"168\"></circle>\n          </svg>\n          <div class=\"absolute inset-0 grid grid-cols-5 pointer-events-none\" data-kid=\"169\">\n            <div class=\"border-l border-white/5\" data-kid=\"170\"></div>\n            <div class=\"border-l border-white/5\" data-kid=\"171\"></div>\n            <div class=\"border-l border-white/5\" data-kid=\"172\"></div>\n            <div class=\"border-l border-white/5\" data-kid=\"173\"></div>\n            <div class=\"border-l border-white/5\" data-kid=\"174\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 container mx-auto px-12\" data-kid=\"175\">\n    <div class=\"text-center mb-24\" data-kid=\"176\">\n      <h2 class=\"text-5xl font-black tracking-tighter\" data-kid=\"177\">The Consensus.</h2>\n    </div>\n\n    <div class=\"grid md:grid-cols-3 gap-8\" data-kid=\"178\">\n      <div class=\"glass-card p-10 relative\" data-kid=\"179\">\n        <div class=\"absolute top-0 left-0 w-1 h-full bg-teal-500/40 rounded-l-2xl\" data-kid=\"180\"></div>\n        <div class=\"flex items-center gap-4 mb-8\" data-kid=\"181\">\n          <div class=\"w-12 h-12 rounded-full bg-teal-500/10 border border-teal-500/20 flex items-center justify-center font-black text-teal-500\" data-kid=\"182\">AS</div>\n          <div data-kid=\"183\">\n            <p class=\"font-bold text-sm\" data-kid=\"184\">Arjun Sharma</p>\n            <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest\" data-kid=\"185\">SDE III, Microsoft</p>\n          </div>\n        </div>\n        <p class=\"text-white/60 leading-relaxed italic\" data-kid=\"186\">\"The simulator decoded my debt cycle. I hit my 5-year goal in 18 months by following the health engine's precision logic.\"</p>\n      </div>\n      \n      <div class=\"glass-card p-10 relative\" data-kid=\"187\">\n        <div class=\"absolute top-0 left-0 w-1 h-full bg-teal-500/40 rounded-l-2xl\" data-kid=\"188\"></div>\n        <div class=\"flex items-center gap-4 mb-8\" data-kid=\"189\">\n          <div class=\"w-12 h-12 rounded-full bg-teal-500/10 border border-teal-500/20 flex items-center justify-center font-black text-teal-500\" data-kid=\"190\">NP</div>\n          <div data-kid=\"191\">\n            <p class=\"font-bold text-sm\" data-kid=\"192\">Neha Patel</p>\n            <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest\" data-kid=\"193\">Product Lead, Razorpay</p>\n          </div>\n        </div>\n        <p class=\"text-white/60 leading-relaxed italic\" data-kid=\"194\">\"Finally, a tool that respects the complexity of the Indian ecosystem. The institutional score is now my primary KPI.\"</p>\n      </div>\n\n      <div class=\"glass-card p-10 relative\" data-kid=\"195\">\n        <div class=\"absolute top-0 left-0 w-1 h-full bg-teal-500/40 rounded-l-2xl\" data-kid=\"196\"></div>\n        <div class=\"flex items-center gap-4 mb-8\" data-kid=\"197\">\n          <div class=\"w-12 h-12 rounded-full bg-teal-500/10 border border-teal-500/20 flex items-center justify-center font-black text-teal-500\" data-kid=\"198\">RK</div>\n          <div data-kid=\"199\">\n            <p class=\"font-bold text-sm\" data-kid=\"200\">Rohan Kapoor</p>\n            <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest\" data-kid=\"201\">Founder, Stealth AI</p>\n          </div>\n        </div>\n        <p class=\"text-white/60 leading-relaxed italic\" data-kid=\"202\">\"It's like having a private banker and a data scientist in your pocket. The clean glass UI makes wealth tracking addictive.\"</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 border-t border-white/5 bg-[#050505]\" data-kid=\"203\">\n    <div class=\"container mx-auto px-12 grid lg:grid-cols-4 gap-20\" data-kid=\"204\">\n      <div class=\"lg:col-span-2\" data-kid=\"205\">\n        <div class=\"flex items-center gap-3 mb-8\" data-kid=\"206\">\n          <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-[#D4AF37] to-[#b8860b] flex items-center justify-center font-black text-black text-sm\" data-kid=\"207\">₹</div>\n          <span class=\"font-display font-black text-xl tracking-tighter\" data-kid=\"208\">BFHE</span>\n        </div>\n        <p class=\"text-white/30 text-sm max-w-sm mb-10 leading-relaxed\" data-kid=\"209\">\n          Bharat Financial Health Engine. Institutional-grade intelligence for the modern Indian wealth creator.\n        </p>\n        <div class=\"flex gap-6\" data-kid=\"210\">\n          <i class=\"ti ti-brand-twitter text-white/20 hover:text-white text-xl cursor-pointer\" data-kid=\"211\"></i>\n          <i class=\"ti ti-brand-linkedin text-white/20 hover:text-white text-xl cursor-pointer\" data-kid=\"212\"></i>\n          <i class=\"ti ti-brand-instagram text-white/20 hover:text-white text-xl cursor-pointer\" data-kid=\"213\"></i>\n        </div>\n      </div>\n      \n      <div class=\"space-y-6\" data-kid=\"214\">\n        <p class=\"text-[10px] font-black text-white/20 uppercase tracking-[0.3em]\" data-kid=\"215\">Protocol</p>\n        <div class=\"flex flex-col gap-4 text-sm font-bold text-white/50\" data-kid=\"216\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"217\">Scoring Logic</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"218\">Encryption</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"219\">API Documentation</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"220\">Security Audit</a>\n        </div>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"221\">\n        <p class=\"text-[10px] font-black text-white/20 uppercase tracking-[0.3em]\" data-kid=\"222\">Institutional</p>\n        <div class=\"flex flex-col gap-4 text-sm font-bold text-white/50\" data-kid=\"223\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"224\">Partner Program</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"225\">Tax Compliance</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"226\">Legal Framework</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"227\">Privacy Charter</a>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"container mx-auto px-12 mt-20 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between gap-6 text-[10px] font-black text-white/20 uppercase tracking-widest\" data-kid=\"228\">\n      <p data-kid=\"229\">© 2026 Bharat Financial Health Engine. All systems operational.</p>\n      <div class=\"flex gap-10\" data-kid=\"230\">\n        <span data-kid=\"231\">ISO 27001 Certified</span>\n        <span data-kid=\"232\">Made for Bharat</span>\n      </div>\n    </div>\n  </footer>\n</div>",
